@model RecuperarPasswordViewModel
@{
    Layout = "_LayoutLogin";
    ViewData["Title"] = "Recuperar contraseña";
}

<div class="login-page">
  <div class="login-card">
    <h1 class="login-heading" style="font-size:1.375rem">Recuperar contraseña</h1>
    <p class="login-sub">Te enviaremos las instrucciones a tu correo registrado.</p>

    <form asp-action="RecuperarPassword" method="post">
      @Html.AntiForgeryToken()
      <div asp-validation-summary="ModelOnly" class="form-error" role="alert" style="margin-bottom:var(--sp-3)"></div>

      <div class="form-group">
        <label asp-for="CorreoAcceso" class="form-label">Correo electrónico</label>
        <input asp-for="CorreoAcceso" class="form-input" type="email" autocomplete="email" placeholder="nombre@empresa.com…" />
        <span asp-validation-for="CorreoAcceso" class="form-error"></span>
      </div>

      <button type="submit" class="btn btn-primary btn-lg" style="width:100%;margin-top:var(--sp-2)">
        Enviar instrucciones
      </button>
    </form>

    <div style="text-align:center;margin-top:var(--sp-4)">
      <a asp-action="Login" style="font-size:.875rem;color:var(--c-brand-600)">← Volver al inicio de sesión</a>
    </div>
  </div>
</div>
