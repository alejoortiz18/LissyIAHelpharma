@model CambiarPasswordViewModel
@{
    ViewData["Title"] = "Cambiar contraseña";
    ViewData["BreadcrumbCurrent"] = "Cambiar contraseña";
}

<div class="page-header">
  <div class="page-header-info">
    <h1 class="page-title">Cambiar contraseña</h1>
    <p class="page-desc">@(SesionHelper.GetDebeCambiarPassword(User) ? "Debes cambiar tu contraseña temporal antes de continuar." : "Actualiza tu contraseña de acceso al sistema.")</p>
  </div>
</div>

@if (SesionHelper.GetDebeCambiarPassword(User))
{
  <div class="alert alert--warning" style="margin-bottom:var(--sp-5)" role="alert">
    <div class="alert-body">
      <p class="alert-title">Contraseña temporal</p>
      <p>Por seguridad debes establecer una nueva contraseña antes de usar el sistema.</p>
    </div>
  </div>
}

<form asp-action="CambiarPassword" method="post" style="max-width:28rem">
  @Html.AntiForgeryToken()
  <div asp-validation-summary="ModelOnly" class="form-error" role="alert" style="margin-bottom:var(--sp-3)"></div>

  <div class="form-section">
    <div class="form-section-body">
      <div class="form-group">
        <label asp-for="Dto.PasswordActual" class="form-label">
          Contraseña actual <span class="required" aria-hidden="true">*</span>
        </label>
        <input asp-for="Dto.PasswordActual" class="form-input" type="password" autocomplete="current-password" />
        <span asp-validation-for="Dto.PasswordActual" class="form-error"></span>
      </div>
      <div class="form-group">
        <label asp-for="Dto.NuevoPassword" class="form-label">
          Nueva contraseña <span class="required" aria-hidden="true">*</span>
        </label>
        <input asp-for="Dto.NuevoPassword" class="form-input" type="password" autocomplete="new-password" />
        <span asp-validation-for="Dto.NuevoPassword" class="form-error"></span>
        <span class="form-hint">Mínimo 8 caracteres.</span>
      </div>
      <div class="form-group">
        <label asp-for="Dto.ConfirmarPassword" class="form-label">
          Confirmar nueva contraseña <span class="required" aria-hidden="true">*</span>
        </label>
        <input asp-for="Dto.ConfirmarPassword" class="form-input" type="password" autocomplete="new-password" />
        <span asp-validation-for="Dto.ConfirmarPassword" class="form-error"></span>
      </div>
    </div>
  </div>

  <div style="display:flex;gap:var(--sp-3);padding-top:var(--sp-4)">
    <button type="submit" class="btn btn-primary btn-lg">Guardar contraseña</button>
    @if (!SesionHelper.GetDebeCambiarPassword(User))
    {
      <a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary btn-lg">Cancelar</a>
    }
  </div>
</form>
