@model RestablecerPasswordViewModel
@{
    Layout = "_LayoutLogin";
    ViewData["Title"] = "Restablecer contraseña";
}

<div class="login-page">
  <div class="login-card">
    <h1 class="login-heading" style="font-size:1.375rem">Nueva contraseña</h1>
    <p class="login-sub">Ingresa tu nueva contraseña (mínimo 8 caracteres).</p>

    <form asp-action="RestablecerPassword" method="post">
      @Html.AntiForgeryToken()
      <input asp-for="Token" type="hidden" />
      <div asp-validation-summary="ModelOnly" class="form-error" role="alert" style="margin-bottom:var(--sp-3)"></div>

      <div class="form-group">
        <label asp-for="NuevoPassword" class="form-label">Nueva contraseña</label>
        <input asp-for="NuevoPassword" class="form-input" type="password" autocomplete="new-password" />
        <span asp-validation-for="NuevoPassword" class="form-error"></span>
      </div>
      <div class="form-group">
        <label asp-for="ConfirmarPassword" class="form-label">Confirmar contraseña</label>
        <input asp-for="ConfirmarPassword" class="form-input" type="password" autocomplete="new-password" />
        <span asp-validation-for="ConfirmarPassword" class="form-error"></span>
      </div>

      <button type="submit" class="btn btn-primary btn-lg" style="width:100%;margin-top:var(--sp-2)">
        Guardar nueva contraseña
      </button>
    </form>
  </div>
</div>
