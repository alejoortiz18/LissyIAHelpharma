@model RestablecerPasswordViewModel
@{
    Layout = "_LayoutLogin";
    ViewData["Title"] = "Restablecer contraseña";
}

<div class="login-page">
  <div class="login-card">
    <h1 class="login-heading" style="font-size:1.375rem">Nueva contraseña</h1>
    <p class="login-sub">Ingresa tu nueva contraseña (mínimo 8 caracteres).</p>

    <form asp-action="RestablecerPassword" method="post">
      @Html.AntiForgeryToken()
      <input asp-for="Token" type="hidden" />
      <div asp-validation-summary="ModelOnly" class="form-error" role="alert" style="margin-bottom:var(--sp-3)"></div>

      <div class="form-group">
        <label asp-for="NuevoPassword" class="form-label">Nueva contraseña</label>
        <div style="position:relative">
          <input asp-for="NuevoPassword" id="inputNuevoPassword" class="form-input" type="password"
                 autocomplete="new-password" style="padding-right:2.75rem" />
          <button type="button" id="btnToggleNuevo"
                  aria-label="Mostrar u ocultar contraseña"
                  style="position:absolute;top:50%;right:.75rem;transform:translateY(-50%);
                         background:none;border:none;padding:0;cursor:pointer;
                         color:var(--color-text-muted,#6b7280);line-height:1">
            <svg id="iconNuevoOpen" xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
            <svg id="iconNuevoOff" xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 style="display:none">
              <path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94"/>
              <path d="M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19"/>
              <line x1="1" y1="1" x2="23" y2="23"/>
            </svg>
          </button>
        </div>
        <span asp-validation-for="NuevoPassword" class="form-error"></span>
      </div>
      <div class="form-group">
        <label asp-for="ConfirmarPassword" class="form-label">Confirmar contraseña</label>
        <div style="position:relative">
          <input asp-for="ConfirmarPassword" id="inputConfirmarPassword" class="form-input" type="password"
                 autocomplete="new-password" style="padding-right:2.75rem" />
          <button type="button" id="btnToggleConfirmar"
                  aria-label="Mostrar u ocultar contraseña"
                  style="position:absolute;top:50%;right:.75rem;transform:translateY(-50%);
                         background:none;border:none;padding:0;cursor:pointer;
                         color:var(--color-text-muted,#6b7280);line-height:1">
            <svg id="iconConfirmarOpen" xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
            <svg id="iconConfirmarOff" xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 style="display:none">
              <path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94"/>
              <path d="M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19"/>
              <line x1="1" y1="1" x2="23" y2="23"/>
            </svg>
          </button>
        </div>
        <span asp-validation-for="ConfirmarPassword" class="form-error"></span>
      </div>

      <button type="submit" class="btn btn-primary btn-lg" style="width:100%;margin-top:var(--sp-2)">
        Guardar nueva contraseña
      </button>
    </form>
  </div>
</div>

@section Scripts {
  <script>
    (function () {
      function togglePassword(inputId, btnId, openIconId, offIconId) {
        var input = document.getElementById(inputId);
        var btn   = document.getElementById(btnId);
        var open  = document.getElementById(openIconId);
        var off   = document.getElementById(offIconId);
        btn.addEventListener('click', function () {
          var show = input.type === 'password';
          input.type = show ? 'text' : 'password';
          open.style.display = show ? 'none' : '';
          off.style.display  = show ? ''     : 'none';
          btn.setAttribute('aria-label', show ? 'Ocultar contraseña' : 'Mostrar contraseña');
        });
      }
      togglePassword('inputNuevoPassword',    'btnToggleNuevo',    'iconNuevoOpen',    'iconNuevoOff');
      togglePassword('inputConfirmarPassword', 'btnToggleConfirmar', 'iconConfirmarOpen', 'iconConfirmarOff');
    })();
  </script>
}
