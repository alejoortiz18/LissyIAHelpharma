@model HorasExtrasViewModel
@{
    ViewData["Title"] = "Horas extras";
    ViewData["BreadcrumbCurrent"] = "Horas extras";
    var rol    = SesionHelper.GetRol(User);
    var empId  = SesionHelper.GetEmpleadoId(User);
    bool puedeAprobar = rol == RolUsuario.Jefe || rol == RolUsuario.Regente || rol == RolUsuario.AuxiliarRegente;
}

<div class="page-header">
  <div class="page-header-info">
    <h1 class="page-title">Horas extras</h1>
    <p class="page-desc">@Model.TotalRegistros registros encontrados.</p>
  </div>
  <div class="page-actions">
    <a asp-action="Crear" class="btn btn-primary">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Nueva solicitud
    </a>
  </div>
</div>

@if (TempData["Exito"] != null)
{
  <div class="alert alert--success alert-dismissible" role="alert">@TempData["Exito"]</div>
}
@if (TempData["Error"] != null)
{
  <div class="alert alert--error alert-dismissible" role="alert">@TempData["Error"]</div>
}

<!-- Stats -->
<div class="stats-grid" style="--cols:3;gap:var(--sp-4);margin-bottom:var(--sp-5)">
  <div class="stat-card">
    <span class="stat-label">Pendientes</span>
    <span class="stat-value">@Model.Pendientes</span>
  </div>
  <div class="stat-card">
    <span class="stat-label">Aprobadas este mes</span>
    <span class="stat-value">@Model.AprobadasEsteMes</span>
  </div>
  <div class="stat-card">
    <span class="stat-label">Total horas aprobadas</span>
    <span class="stat-value">@Model.TotalHorasAprobadas h</span>
  </div>
</div>

<!-- Filtros -->
<form method="get" class="filter-bar" role="search" aria-label="Filtros de horas extras">
  @if (puedeAprobar)
  {
    <input name="buscar" type="search" class="form-input filter-search"
           placeholder="Buscar empleado…" value="@Model.Buscar" autocomplete="off" aria-label="Buscar por empleado" />
  }
  <input name="fecha" type="month" class="form-input" value="@Model.Fecha" aria-label="Mes" />
  <select name="estado" class="form-select" aria-label="Estado">
    <option value="">Todos los estados</option>
    <option value="Pendiente"  selected="@(Model.Estado == "Pendiente")">Pendiente</option>
    <option value="Aprobado"   selected="@(Model.Estado == "Aprobado")">Aprobado</option>
    <option value="Rechazado"  selected="@(Model.Estado == "Rechazado")">Rechazado</option>
    <option value="Anulado"    selected="@(Model.Estado == "Anulado")">Anulado</option>
  </select>
  <button type="submit" class="btn btn-secondary btn-sm">Filtrar</button>
  @if (!string.IsNullOrEmpty(Model.Buscar) || !string.IsNullOrEmpty(Model.Fecha) || !string.IsNullOrEmpty(Model.Estado))
  {
    <a asp-action="Index" class="btn btn-ghost btn-sm">Limpiar</a>
  }
</form>

<!-- Tabla -->
@if (!Model.HorasExtras.Any())
{
<div class="empty-state">
  <div class="empty-icon" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
    </svg>
  </div>
  <p class="empty-title">Sin registros</p>
  <p class="empty-desc">No hay solicitudes con los filtros seleccionados.</p>
</div>
}
else
{
  <div class="table-scroll">
        <table aria-label="Horas extras">
          <thead>
            <tr>
              @if (puedeAprobar) { <th>Empleado</th> <th>Sede</th> }
              <th>Fecha</th>
              <th>Horas</th>
              <th>Motivo</th>
              <th>Estado</th>
              <th><span class="sr-only">Acciones</span></th>
            </tr>
          </thead>
          <tbody>
            @foreach (var h in Model.HorasExtras)
            {
              bool esPropia = empId.HasValue && h.EmpleadoId == empId.Value;
              <tr>
                @if (puedeAprobar)
                {
                  <td>
                    <a asp-controller="Empleado" asp-action="Perfil" asp-route-id="@h.EmpleadoId"
                       asp-route-tab="historial" class="table-link">@h.EmpleadoNombre</a>
                  </td>
                  <td>@h.SedeNombre</td>
                }
                <td class="tabular-nums" style="font-size:.8125rem">@h.FechaTrabajada</td>
                <td class="tabular-nums">@h.CantidadHoras h</td>
                <td style="font-size:.8125rem;max-width:14rem;white-space:normal">@h.Motivo</td>
                <td>@Html.Raw(BadgeEstado(h.Estado))</td>
                <td>
                  <div style="display:flex;gap:var(--sp-2);align-items:center">
                    @if (h.Estado == "Pendiente" && puedeAprobar && !esPropia)
                    {
                      <form asp-action="Aprobar" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@h.Id" />
                        <button type="submit" class="btn btn-primary btn-sm">Aprobar</button>
                      </form>
                      <form asp-action="Rechazar" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@h.Id" />
                        <input type="hidden" name="motivoRechazo" value="Rechazado por supervisor" />
                        <button type="submit" class="btn btn-ghost btn-sm"
                                onclick="return confirm('¿Rechazar esta solicitud?')">Rechazar</button>
                      </form>
                    }
                    else if (h.Estado == "Pendiente" && esPropia)
                    {
                      <span style="font-size:.8125rem;color:var(--c-gray-500)">Pendiente de revisión</span>
                    }
                    @if (h.Estado == "Aprobado" && puedeAprobar)
                    {
                      <form asp-action="Anular" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@h.Id" />
                        <input type="hidden" name="motivoAnulacion" value="Anulado por supervisor" />
                        <button type="submit" class="btn btn-ghost btn-sm"
                                onclick="return confirm('¿Anular esta hora extra aprobada?')">Anular</button>
                      </form>
                    }
                  </div>
                </td>
              </tr>
            }
          </tbody>
        </table>
  </div>

  @if (Model.TotalPaginas > 1)
  {
    <div class="pagination">
      <span class="pagination-info">Página @Model.Pagina de @Model.TotalPaginas</span>
      <div class="pagination-controls">
        @if (Model.Pagina > 1)
        {
          <a asp-action="Index" asp-route-buscar="@Model.Buscar" asp-route-fecha="@Model.Fecha"
             asp-route-estado="@Model.Estado" asp-route-pagina="@(Model.Pagina - 1)" class="page-btn">&#8249;</a>
        }
        @for (int p = 1; p <= Model.TotalPaginas; p++)
        {
          <a asp-action="Index" asp-route-buscar="@Model.Buscar" asp-route-fecha="@Model.Fecha"
             asp-route-estado="@Model.Estado" asp-route-pagina="@p"
             class="page-btn @(p == Model.Pagina ? "is-active" : "")">@p</a>
        }
        @if (Model.Pagina < Model.TotalPaginas)
        {
          <a asp-action="Index" asp-route-buscar="@Model.Buscar" asp-route-fecha="@Model.Fecha"
             asp-route-estado="@Model.Estado" asp-route-pagina="@(Model.Pagina + 1)" class="page-btn">&#8250;</a>
        }
      </div>
    </div>
  }
}

@functions {
    string BadgeEstado(string estado) => estado.ToLower() switch
    {
        "pendiente"  => "<span class=\"badge badge--pendiente\">Pendiente</span>",
        "aprobado"   => "<span class=\"badge badge--activo\"><span class=\"badge-dot\"></span>Aprobado</span>",
        "rechazado"  => "<span class=\"badge badge--inactivo\"><span class=\"badge-dot\"></span>Rechazado</span>",
        "anulado"    => "<span class=\"badge badge--anulado\"><span class=\"badge-dot\"></span>Anulado</span>",
        _            => $"<span class=\"badge\">{System.Net.WebUtility.HtmlEncode(estado)}</span>",
    };
}
