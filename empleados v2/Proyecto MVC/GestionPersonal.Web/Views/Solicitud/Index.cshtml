@model SolicitudesViewModel
@using GestionPersonal.Web.ViewModels.Solicitud
@{
    ViewData["Title"] = "Mis Solicitudes";
    ViewData["BreadcrumbCurrent"] = "Mis Solicitudes";
}

<div class="page-header">
  <div class="page-header-info">
    <h1 class="page-title">Mis Solicitudes</h1>
    <p class="page-desc">Vacaciones, incapacidades y permisos solicitados.</p>
  </div>
  <div class="page-actions">
    <button class="btn btn-primary" data-modal-open="modal-nueva-solicitud">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Nueva solicitud
    </button>
  </div>
</div>

@if (TempData["Exito"] != null)
{
  <div class="alert alert--success alert-dismissible" role="alert">@TempData["Exito"]</div>
}
@if (TempData["Error"] != null)
{
  <div class="alert alert--error alert-dismissible" role="alert">@TempData["Error"]</div>
}

<!-- Filtros -->
<form method="get" class="filter-bar" role="search" aria-label="Filtros de solicitudes">
  <select name="tipo" class="form-select" aria-label="Tipo de solicitud">
    <option value="">Todos los tipos</option>
    <option value="Vacaciones"  selected="@(Model.Tipo == "Vacaciones")">Vacaciones</option>
    <option value="Incapacidad" selected="@(Model.Tipo == "Incapacidad")">Incapacidad</option>
    <option value="Permiso"     selected="@(Model.Tipo == "Permiso")">Permiso</option>
  </select>
  <select name="estado" class="form-select" aria-label="Estado">
    <option value="">Todos los estados</option>
    <option value="Pendiente"   selected="@(Model.Estado == "Pendiente")">Pendiente</option>
    <option value="EnRevision"  selected="@(Model.Estado == "EnRevision")">En revisión</option>
    <option value="Aprobado"    selected="@(Model.Estado == "Aprobado")">Aprobado</option>
    <option value="Rechazado"   selected="@(Model.Estado == "Rechazado")">Rechazado</option>
    <option value="Cancelado"   selected="@(Model.Estado == "Cancelado")">Cancelado</option>
  </select>
  <button type="submit" class="btn btn-secondary btn-sm">Filtrar</button>
  @if (!string.IsNullOrEmpty(Model.Tipo) || !string.IsNullOrEmpty(Model.Estado))
  {
    <a asp-action="Index" class="btn btn-ghost btn-sm">Limpiar</a>
  }
</form>

<!-- Tabla -->
@if (!Model.Solicitudes.Any())
{
  <div class="table-wrapper">
    <div class="empty-state">
      <div class="empty-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
      </div>
      <p class="empty-title">Sin solicitudes</p>
      <p class="empty-desc">No tienes solicitudes registradas con los filtros seleccionados.</p>
    </div>
  </div>
}
else
{
  <div class="table-wrapper">
    <div class="table-scroll">
      <table aria-label="Mis solicitudes">
        <thead>
          <tr>
            <th scope="col">#</th>
            <th scope="col">Tipo</th>
            <th scope="col">Fecha solicitud</th>
            <th scope="col">Período</th>
            <th scope="col">Días</th>
            <th scope="col">Estado</th>
            <th scope="col">Aprobado por</th>
          </tr>
        </thead>
        <tbody>
          @{ int num = (Model.Pagina - 1) * 15 + 1; }
          @foreach (var s in Model.Solicitudes)
          {
            <tr>
              <td class="tabular-nums" style="color:var(--c-gray-400);font-size:.8125rem">@num</td>
              <td>@Html.Raw(BadgeTipo(s.TipoEvento))</td>
              <td class="tabular-nums" style="font-size:.8125rem;white-space:nowrap">
                @* FechaCreacion no viene en el DTO, usamos FechaInicio como referencia — el DTO sí la tiene *@
                —
              </td>
              <td class="tabular-nums" style="font-size:.8125rem;white-space:nowrap">
                @s.FechaInicio → @s.FechaFin
              </td>
              <td class="tabular-nums" style="font-size:.8125rem">@s.DiasSolicitados días</td>
              <td>@Html.Raw(BadgeEstado(s.Estado))</td>
              <td style="font-size:.8125rem;color:var(--c-gray-600)">
                @if (s.Estado == "Pendiente" || s.Estado == "EnRevision")
                {
                  <span style="color:var(--c-gray-400)">—</span>
                }
                else
                {
                  @s.AutorizadoPor
                }
              </td>
            </tr>
            num++;
          }
        </tbody>
      </table>
    </div>
  </div>

  @if (Model.TotalPaginas > 1)
  {
    <div class="pagination">
      <span class="pagination-info">Página @Model.Pagina de @Model.TotalPaginas</span>
      <div class="pagination-controls">
        @if (Model.Pagina > 1)
        {
          <a asp-action="Index" asp-route-tipo="@Model.Tipo" asp-route-estado="@Model.Estado"
             asp-route-pagina="@(Model.Pagina - 1)" class="page-btn">&#8249;</a>
        }
        @for (int p = 1; p <= Model.TotalPaginas; p++)
        {
          <a asp-action="Index" asp-route-tipo="@Model.Tipo" asp-route-estado="@Model.Estado"
             asp-route-pagina="@p" class="page-btn @(p == Model.Pagina ? "is-active" : "")">@p</a>
        }
        @if (Model.Pagina < Model.TotalPaginas)
        {
          <a asp-action="Index" asp-route-tipo="@Model.Tipo" asp-route-estado="@Model.Estado"
             asp-route-pagina="@(Model.Pagina + 1)" class="page-btn">&#8250;</a>
        }
      </div>
    </div>
  }
}

<!-- ═══════════════════════════════════════════════════════════
     Modal: Nueva solicitud
     ═══════════════════════════════════════════════════════════ -->
<div class="modal-overlay" id="modal-nueva-solicitud" hidden aria-modal="true"
     aria-labelledby="modal-sol-title" role="dialog">
  <div class="modal modal--lg">
    <div class="modal-header">
      <h2 class="modal-title" id="modal-sol-title">Nueva solicitud</h2>
      <button class="modal-close btn" data-modal-close aria-label="Cerrar">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="modal-body">
      <form id="form-solicitud" method="post" asp-action="Crear" novalidate>

        <div class="form-grid form-grid-2" style="margin-bottom:var(--sp-4)">
          <!-- Tipo -->
          <div class="form-group" style="margin-bottom:0">
            <label class="form-label" for="sol-tipo">
              Tipo de solicitud <span class="required" aria-hidden="true">*</span>
            </label>
            <select class="form-select" id="sol-tipo" name="tipoEvento" required>
              <option value="">Selecciona tipo…</option>
              <option value="Vacaciones">Vacaciones</option>
              <option value="Incapacidad">Incapacidad</option>
              <option value="Permiso">Permiso</option>
            </select>
          </div>
        </div>

        <div class="form-grid form-grid-2">
          <!-- Fecha inicio -->
          <div class="form-group">
            <label class="form-label" for="sol-inicio">
              Fecha inicio <span class="required" aria-hidden="true">*</span>
            </label>
            <input class="form-input" type="date" id="sol-inicio" name="fechaInicio" required>
          </div>
          <!-- Fecha fin -->
          <div class="form-group">
            <label class="form-label" for="sol-fin">
              Fecha fin <span class="required" aria-hidden="true">*</span>
            </label>
            <input class="form-input" type="date" id="sol-fin" name="fechaFin" required>
          </div>
        </div>

        <!-- Motivo -->
        <div class="form-group">
          <label class="form-label" for="sol-descripcion">
            Motivo <span class="required" aria-hidden="true">*</span>
          </label>
          <textarea class="form-input" id="sol-descripcion" name="descripcion"
                    rows="3" required maxlength="400"
                    placeholder="Describe brevemente el motivo de tu solicitud…"></textarea>
        </div>

        <!-- Observaciones -->
        <div class="form-group">
          <label class="form-label" for="sol-observaciones">Observaciones</label>
          <textarea class="form-input" id="sol-observaciones" name="observaciones"
                    rows="2" maxlength="300"
                    placeholder="Información adicional (opcional)…"></textarea>
        </div>

        <div id="sol-error" class="alert alert--error" hidden role="alert"></div>

        <div class="modal-footer">
          <button type="button" class="btn btn-ghost" data-modal-close>Cancelar</button>
          <button type="submit" class="btn btn-primary" id="sol-submit">Enviar solicitud</button>
        </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
<script>
(function () {
  'use strict';

  // ── Validación cliente básica ──────────────────────────────────────
  const form    = document.getElementById('form-solicitud');
  const errBox  = document.getElementById('sol-error');
  const inicio  = document.getElementById('sol-inicio');
  const fin     = document.getElementById('sol-fin');

  form.addEventListener('submit', function (e) {
    errBox.hidden = true;
    const errors = [];

    if (!document.getElementById('sol-tipo').value)
      errors.push('Selecciona el tipo de solicitud.');
    if (!inicio.value)
      errors.push('Ingresa la fecha de inicio.');
    if (!fin.value)
      errors.push('Ingresa la fecha de fin.');
    if (inicio.value && fin.value && fin.value < inicio.value)
      errors.push('La fecha de fin no puede ser anterior a la fecha de inicio.');
    if (!document.getElementById('sol-descripcion').value.trim())
      errors.push('El motivo es obligatorio.');

    if (errors.length) {
      e.preventDefault();
      errBox.textContent = errors.join(' ');
      errBox.hidden = false;
    }
  });

  // Fechas mínimas — no se puede solicitar en el pasado (fecha de inicio)
  const hoy = new Date().toISOString().split('T')[0];
  inicio.setAttribute('min', hoy);

  inicio.addEventListener('change', function () {
    fin.setAttribute('min', inicio.value || hoy);
    if (fin.value && fin.value < inicio.value) fin.value = '';
  });
}());
</script>
}

@functions {
    string BadgeEstado(string estado) => estado.ToLower() switch
    {
        "pendiente"   => "<span class=\"badge badge--pendiente\"><span class=\"badge-dot\"></span>Pendiente</span>",
        "enrevision"  => "<span class=\"badge badge--pendiente\"><span class=\"badge-dot\"></span>En revisión</span>",
        "aprobado"    => "<span class=\"badge badge--aprobado\"><span class=\"badge-dot\"></span>Aprobado</span>",
        "rechazado"   => "<span class=\"badge badge--rechazado\"><span class=\"badge-dot\"></span>Rechazado</span>",
        "cancelado"   => "<span class=\"badge badge--finalizado\"><span class=\"badge-dot\"></span>Cancelado</span>",
        "activo"      => "<span class=\"badge badge--activo\"><span class=\"badge-dot\"></span>Activo</span>",
        "finalizado"  => "<span class=\"badge badge--finalizado\"><span class=\"badge-dot\"></span>Finalizado</span>",
        "anulado"     => "<span class=\"badge badge--anulado\"><span class=\"badge-dot\"></span>Anulado</span>",
        _             => $"<span class=\"badge\">{System.Net.WebUtility.HtmlEncode(estado)}</span>",
    };
    string BadgeTipo(string tipo) => tipo.ToLower() switch
    {
        "vacaciones"  => "<span class=\"badge badge--vacaciones\">Vacaciones</span>",
        "incapacidad" => "<span class=\"badge badge--incapacidad\">Incapacidad</span>",
        "permiso"     => "<span class=\"badge badge--permiso\">Permiso</span>",
        _             => $"<span class=\"badge\">{System.Net.WebUtility.HtmlEncode(tipo)}</span>",
    };
}
