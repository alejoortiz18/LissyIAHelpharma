@model CatalogosViewModel
@{
    var maestrosCtrl = ViewData["MaestrosController"] as string ?? "Catalogos";
    var maestrosTitulo = ViewData["MaestrosTitulo"] as string ?? "Catálogos del sistema";
    var maestrosDesc = ViewData["MaestrosDesc"] as string ?? "Administra las sedes, cargos y empresas temporales disponibles.";
    var antiforgery = ViewContext.HttpContext.RequestServices
        .GetRequiredService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>()
        .GetAndStoreTokens(ViewContext.HttpContext).RequestToken;
}

<div class="page-header">
  <div class="page-header-info">
    <h1 class="page-title">@maestrosTitulo</h1>
    <p class="page-desc">@maestrosDesc</p>
  </div>
</div>

<!-- Tabs -->
<div data-tabs-container>
  <div class="tabs" role="tablist" aria-label="Catálogos">
    <a asp-controller="@maestrosCtrl" asp-action="Index" asp-route-tab="sedes"
       class="tab-btn @(Model.Tab == "sedes" ? "is-active" : "")"
       role="tab" aria-selected="@(Model.Tab == "sedes" ? "true" : "false")"
       aria-controls="tab-sedes">Sedes</a>
    <a asp-controller="@maestrosCtrl" asp-action="Index" asp-route-tab="cargos"
       class="tab-btn @(Model.Tab == "cargos" ? "is-active" : "")"
       role="tab" aria-selected="@(Model.Tab == "cargos" ? "true" : "false")"
       aria-controls="tab-cargos">Cargos</a>
    <a asp-controller="@maestrosCtrl" asp-action="Index" asp-route-tab="empresas"
       class="tab-btn @(Model.Tab == "empresas" ? "is-active" : "")"
       role="tab" aria-selected="@(Model.Tab == "empresas" ? "true" : "false")"
       aria-controls="tab-empresas">Empresas temporales</a>
    <a asp-controller="@maestrosCtrl" asp-action="Index" asp-route-tab="tipos-solicitud"
       class="tab-btn @(Model.Tab == "tipos-solicitud" ? "is-active" : "")"
       role="tab" aria-selected="@(Model.Tab == "tipos-solicitud" ? "true" : "false")"
       aria-controls="tab-tipos-solicitud">Tipos de solicitud</a>
    <a asp-controller="@maestrosCtrl" asp-action="Index" asp-route-tab="roles"
       class="tab-btn @(Model.Tab == "roles" ? "is-active" : "")"
       role="tab" aria-selected="@(Model.Tab == "roles" ? "true" : "false")"
       aria-controls="tab-roles">Roles del sistema</a>
  </div>

  <!-- ──────────── TAB: Sedes ──────────── -->
  @if (Model.Tab == "sedes")
  {
    <div class="tab-panel is-active" role="tabpanel" id="tab-sedes" tabindex="0">
      <div class="card">
        <div class="card-header">
          <div>
            <h2 class="card-title">Sedes</h2>
            <p class="card-desc">Ubicaciones donde opera la empresa.</p>
          </div>
          <button class="btn btn-primary btn-sm" onclick="abrirCrearSede()" id="btn-nueva-sede">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Nueva sede
          </button>
        </div>
        @if (!Model.Sedes.Any())
        {
          <div class="card-body">
            <div class="empty-state">
              <p class="empty-title">Sin sedes registradas</p>
              <p class="empty-desc">Crea la primera sede usando el botón "Nueva sede".</p>
            </div>
          </div>
        }
        else
        {
          <div class="table-wrapper">
            <div class="table-scroll">
              <table aria-label="Sedes">
                <thead>
                  <tr>
                    <th scope="col">Nombre</th>
                    <th scope="col">Ciudad</th>
                    <th scope="col">Dirección</th>
                    <th scope="col">Estado</th>
                    <th scope="col"><span class="sr-only">Acciones</span></th>
                  </tr>
                </thead>
                <tbody>
                  @foreach (var s in Model.Sedes)
                  {
                    <tr>
                      <td style="font-weight:600">@s.Nombre</td>
                      <td>@s.Ciudad</td>
                      <td style="font-size:.8125rem">@(s.Direccion ?? "—")</td>
                      <td>
                        @if (s.Estado == "Activa")
                        { <span class="badge badge--activo"><span class="badge-dot"></span>Activa</span> }
                        else
                        { <span class="badge badge--inactivo"><span class="badge-dot"></span>Inactiva</span> }
                      </td>
                      <td>
                        <div class="table-actions">
                          <button type="button" class="btn btn-ghost btn-sm"
                                  onclick="abrirEditarSede(this)"
                                  data-id="@s.Id"
                                  data-nombre="@s.Nombre"
                                  data-ciudad="@s.Ciudad"
                                  data-direccion="@(s.Direccion ?? "")"
                                  aria-label="Editar sede @s.Nombre">
                            Editar
                          </button>
                          @if (s.Estado == "Activa")
                          {
                            <button type="button" class="btn btn-ghost btn-sm btn-danger-text"
                                    onclick="darDeBajaSede(this)"
                                    data-id="@s.Id"
                                    data-nombre="@s.Nombre"
                                    aria-label="Eliminar o inactivar sede @s.Nombre">
                              Eliminar
                            </button>
                          }
                          else
                          {
                            <button type="button" class="btn btn-ghost btn-sm"
                                    onclick="activarSede(this)"
                                    data-id="@s.Id"
                                    data-nombre="@s.Nombre"
                                    aria-label="Activar sede @s.Nombre">
                              Activar
                            </button>
                          }
                        </div>
                      </td>
                    </tr>
                  }
                </tbody>
              </table>
            </div>
          </div>
        }
      </div>
    </div>
  }

  <!-- ──────────── TAB: Cargos ──────────── -->
  @if (Model.Tab == "cargos")
  {
    <div class="tab-panel is-active" role="tabpanel" id="tab-cargos" tabindex="0">
      <div class="card">
        <div class="card-header">
          <div>
            <h2 class="card-title">Cargos</h2>
            <p class="card-desc">Posiciones laborales disponibles para los empleados.</p>
          </div>
          <button class="btn btn-primary btn-sm" onclick="abrirCrearCargo()" id="btn-nuevo-cargo">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Nuevo cargo
          </button>
        </div>
        @if (!Model.Cargos.Any())
        {
          <div class="card-body">
            <div class="empty-state">
              <p class="empty-title">Sin cargos registrados</p>
              <p class="empty-desc">Crea el primer cargo usando el botón "Nuevo cargo".</p>
            </div>
          </div>
        }
        else
        {
          <div class="table-wrapper">
            <div class="table-scroll">
              <table aria-label="Cargos">
                <thead>
                  <tr>
                    <th scope="col">Nombre del cargo</th>
                    <th scope="col">Estado</th>
                    <th scope="col"><span class="sr-only">Acciones</span></th>
                  </tr>
                </thead>
                <tbody>
                  @foreach (var c in Model.Cargos)
                  {
                    <tr>
                      <td style="font-weight:600">@c.Nombre</td>
                      <td>
                        @if (c.Estado == "Activo")
                        { <span class="badge badge--activo"><span class="badge-dot"></span>Activo</span> }
                        else
                        { <span class="badge badge--inactivo"><span class="badge-dot"></span>Inactivo</span> }
                      </td>
                      <td>
                        <div class="table-actions">
                          <button type="button" class="btn btn-ghost btn-sm"
                                  onclick="abrirEditarCargo(this)"
                                  data-id="@c.Id"
                                  data-nombre="@c.Nombre"
                                  aria-label="Editar cargo @c.Nombre">
                            Editar
                          </button>
                          @if (c.Estado == "Activo")
                          {
                            <button type="button" class="btn btn-ghost btn-sm btn-danger-text"
                                    onclick="darDeBajaCargo(this)"
                                    data-id="@c.Id"
                                    data-nombre="@c.Nombre"
                                    aria-label="Eliminar o inactivar cargo @c.Nombre">
                              Eliminar
                            </button>
                          }
                          else
                          {
                            <button type="button" class="btn btn-ghost btn-sm"
                                    onclick="activarCargo(this)"
                                    data-id="@c.Id"
                                    data-nombre="@c.Nombre"
                                    aria-label="Activar cargo @c.Nombre">
                              Activar
                            </button>
                          }
                        </div>
                      </td>
                    </tr>
                  }
                </tbody>
              </table>
            </div>
          </div>
        }
      </div>
    </div>
  }

  <!-- ──────────── TAB: Empresas temporales ──────────── -->
  @if (Model.Tab == "empresas")
  {
    <div class="tab-panel is-active" role="tabpanel" id="tab-empresas" tabindex="0">
      <div class="card">
        <div class="card-header">
          <div>
            <h2 class="card-title">Empresas temporales</h2>
            <p class="card-desc">Agencias que proveen empleados con contratación temporal.</p>
          </div>
          <button class="btn btn-primary btn-sm" onclick="abrirCrearEmpresa()" id="btn-nueva-empresa">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Nueva empresa
          </button>
        </div>
        @if (!Model.EmpresasTemporales.Any())
        {
          <div class="card-body">
            <div class="empty-state">
              <p class="empty-title">Sin empresas temporales registradas</p>
              <p class="empty-desc">Crea la primera empresa usando el botón "Nueva empresa".</p>
            </div>
          </div>
        }
        else
        {
          <div class="table-wrapper">
            <div class="table-scroll">
              <table aria-label="Empresas temporales">
                <thead>
                  <tr>
                    <th scope="col">Nombre</th>
                    <th scope="col">Estado</th>
                    <th scope="col"><span class="sr-only">Acciones</span></th>
                  </tr>
                </thead>
                <tbody>
                  @foreach (var emp in Model.EmpresasTemporales)
                  {
                    <tr>
                      <td style="font-weight:600">@emp.Nombre</td>
                      <td>
                        @if (emp.Estado == "Activa")
                        { <span class="badge badge--activo"><span class="badge-dot"></span>Activa</span> }
                        else
                        { <span class="badge badge--inactivo"><span class="badge-dot"></span>Inactiva</span> }
                      </td>
                      <td>
                        <div class="table-actions">
                          <button type="button" class="btn btn-ghost btn-sm"
                                  onclick="abrirEditarEmpresa(this)"
                                  data-id="@emp.Id"
                                  data-nombre="@emp.Nombre"
                                  aria-label="Editar empresa @emp.Nombre">
                            Editar
                          </button>
                          @if (emp.Estado == "Activa")
                          {
                            <button type="button" class="btn btn-ghost btn-sm btn-danger-text"
                                    onclick="darDeBajaEmpresa(this)"
                                    data-id="@emp.Id"
                                    data-nombre="@emp.Nombre"
                                    aria-label="Eliminar o inactivar empresa @emp.Nombre">
                              Eliminar
                            </button>
                          }
                          else
                          {
                            <button type="button" class="btn btn-ghost btn-sm"
                                    onclick="activarEmpresa(this)"
                                    data-id="@emp.Id"
                                    data-nombre="@emp.Nombre"
                                    aria-label="Activar empresa @emp.Nombre">
                              Activar
                            </button>
                          }
                        </div>
                      </td>
                    </tr>
                  }
                </tbody>
              </table>
            </div>
          </div>
        }
      </div>
    </div>
  }

  <!-- ──────────── TAB: Tipos de solicitud ──────────── -->
  @if (Model.Tab == "tipos-solicitud")
  {
    <div class="tab-panel is-active" role="tabpanel" id="tab-tipos-solicitud" tabindex="0">
      <div class="card">
        <div class="card-header">
          <div>
            <h2 class="card-title">Tipos de solicitud</h2>
            <p class="card-desc">Opciones que verán los operarios al crear una solicitud laboral.</p>
          </div>
          <button class="btn btn-primary btn-sm" onclick="abrirCrearTipoSolicitud()" id="btn-nuevo-tipo-solicitud">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Nuevo tipo
          </button>
        </div>
        @if (!Model.TiposSolicitud.Any())
        {
          <div class="card-body">
            <div class="empty-state">
              <p class="empty-title">Sin tipos de solicitud</p>
              <p class="empty-desc">Crea el primer tipo para que los operarios puedan registrar solicitudes.</p>
            </div>
          </div>
        }
        else
        {
          <div class="table-wrapper">
            <div class="table-scroll">
              <table aria-label="Tipos de solicitud">
                <thead>
                  <tr>
                    <th scope="col">Nombre</th>
                    <th scope="col">Código</th>
                    <th scope="col">Vacaciones</th>
                    <th scope="col">Estado</th>
                    <th scope="col"><span class="sr-only">Acciones</span></th>
                  </tr>
                </thead>
                <tbody>
                  @foreach (var t in Model.TiposSolicitud)
                  {
                    <tr>
                      <td style="font-weight:600">@t.Nombre</td>
                      <td><code>@t.Codigo</code></td>
                      <td>@(t.EsVacaciones ? "Sí" : "No")</td>
                      <td>
                        @if (t.Estado == "Activo")
                        { <span class="badge badge--activo"><span class="badge-dot"></span>Activo</span> }
                        else
                        { <span class="badge badge--inactivo"><span class="badge-dot"></span>Inactivo</span> }
                      </td>
                      <td>
                        <div class="table-actions">
                          <button type="button" class="btn btn-ghost btn-sm"
                                  onclick="abrirEditarTipoSolicitud(this)"
                                  data-id="@t.Id"
                                  data-nombre="@t.Nombre"
                                  data-codigo="@t.Codigo"
                                  data-es-vacaciones="@(t.EsVacaciones ? "1" : "0")"
                                  aria-label="Editar tipo @t.Nombre">
                            Editar
                          </button>
                          @if (t.Estado == "Activo")
                          {
                            <button type="button" class="btn btn-ghost btn-sm btn-danger-text"
                                    onclick="darDeBajaTipoSolicitud(this)"
                                    data-id="@t.Id"
                                    data-nombre="@t.Nombre"
                                    aria-label="Inactivar tipo @t.Nombre">
                              Eliminar
                            </button>
                          }
                          else
                          {
                            <button type="button" class="btn btn-ghost btn-sm"
                                    onclick="activarTipoSolicitud(this)"
                                    data-id="@t.Id"
                                    data-nombre="@t.Nombre"
                                    aria-label="Activar tipo @t.Nombre">
                              Activar
                            </button>
                          }
                        </div>
                      </td>
                    </tr>
                  }
                </tbody>
              </table>
            </div>
          </div>
        }
      </div>
    </div>
  }

  <!-- ──────────── TAB: Roles del sistema ──────────── -->
  @if (Model.Tab == "roles")
  {
    <div class="tab-panel is-active" role="tabpanel" id="tab-roles" tabindex="0">
      <div class="card">
        <div class="card-header">
          <div>
            <h2 class="card-title">Roles del sistema</h2>
            <p class="card-desc">Define qué módulos y acciones puede usar cada rol en la plataforma.</p>
          </div>
          <button class="btn btn-primary btn-sm" onclick="abrirCrearRol()" id="btn-nuevo-rol">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Nuevo rol
          </button>
        </div>
        @if (!Model.RolesSistema.Any())
        {
          <div class="card-body">
            <div class="empty-state">
              <p class="empty-title">Sin roles configurados</p>
              <p class="empty-desc">Ejecuta la migración de BD o crea el primer rol.</p>
            </div>
          </div>
        }
        else
        {
          <div class="table-wrapper">
            <div class="table-scroll">
              <table aria-label="Roles del sistema">
                <thead>
                  <tr>
                    <th scope="col">Código</th>
                    <th scope="col">Nombre</th>
                    <th scope="col">Permisos</th>
                    <th scope="col">Tipo</th>
                    <th scope="col">Estado</th>
                    <th scope="col"><span class="sr-only">Acciones</span></th>
                  </tr>
                </thead>
                <tbody>
                  @foreach (var rol in Model.RolesSistema)
                  {
                    <tr>
                      <td><code style="font-size:.75rem">@rol.Codigo</code></td>
                      <td style="font-weight:600">@RolesSistemaTextos.Nombre(rol.Codigo, rol.Nombre)</td>
                      <td>@rol.Permisos.Count</td>
                      <td>@(rol.EsRolSistema ? "Sistema" : "Personalizado")</td>
                      <td>
                        @if (rol.Estado == "Activo")
                        { <span class="badge badge--activo"><span class="badge-dot"></span>Activo</span> }
                        else
                        { <span class="badge badge--inactivo"><span class="badge-dot"></span>Inactivo</span> }
                      </td>
                      <td>
                        <div class="table-actions">
                          <button type="button" class="btn btn-ghost btn-sm"
                                  onclick="abrirEditarRol(@rol.Id)"
                                  aria-label="Editar rol @rol.Nombre">
                            Editar permisos
                          </button>
                          @if (rol.Estado == "Activo")
                          {
                            <button type="button" class="btn btn-ghost btn-sm btn-danger-text"
                                    onclick="darDeBajaRol(this)"
                                    data-id="@rol.Id"
                                    data-nombre="@RolesSistemaTextos.Nombre(rol.Codigo, rol.Nombre)"
                                    aria-label="Eliminar o inactivar rol @rol.Nombre">
                              Eliminar
                            </button>
                          }
                          else
                          {
                            <button type="button" class="btn btn-ghost btn-sm"
                                    onclick="activarRol(this)"
                                    data-id="@rol.Id"
                                    data-nombre="@RolesSistemaTextos.Nombre(rol.Codigo, rol.Nombre)"
                                    aria-label="Activar rol @rol.Nombre">
                              Activar
                            </button>
                          }
                        </div>
                      </td>
                    </tr>
                  }
                </tbody>
              </table>
            </div>
          </div>
        }
      </div>
    </div>
  }

</div><!-- /data-tabs-container -->

<!-- ═══════════════════════════════════════════════════════════
     Modal: Sede (crear / editar)
     ═══════════════════════════════════════════════════════════ -->
<div class="modal-overlay" id="modal-sede" hidden aria-modal="true"
     aria-labelledby="sede-title" role="dialog">
  <div class="modal">
    <div class="modal-header">
      <h2 class="modal-title" id="sede-title">Nueva sede</h2>
      <button class="modal-close btn" data-modal-close aria-label="Cerrar">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="modal-body">
      <form id="form-sede" novalidate>
        <div class="form-group">
          <label class="form-label" for="sede-nombre">
            Nombre de la sede <span class="required" aria-hidden="true">*</span>
          </label>
          <input class="form-input" type="text" id="sede-nombre" maxlength="200"
                 placeholder="Ej. Sede Norte" autocomplete="off" required>
        </div>
        <div class="form-grid form-grid-2">
          <div class="form-group">
            <label class="form-label" for="sede-ciudad">
              Ciudad <span class="required" aria-hidden="true">*</span>
            </label>
            <input class="form-input" type="text" id="sede-ciudad" maxlength="100"
                   placeholder="Ej. Bogotá" autocomplete="off" required>
          </div>
          <div class="form-group">
            <label class="form-label" for="sede-direccion">
              Dirección <span class="required" aria-hidden="true">*</span>
            </label>
            <input class="form-input" type="text" id="sede-direccion" maxlength="300"
                   placeholder="Ej. Cra 15 # 90-12" autocomplete="off" required>
          </div>
        </div>
      </form>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" data-modal-close>Cancelar</button>
      <button class="btn btn-primary" id="btn-guardar-sede">Crear sede</button>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════
     Modal: Cargo (crear / editar)
     ═══════════════════════════════════════════════════════════ -->
<div class="modal-overlay" id="modal-cargo" hidden aria-modal="true"
     aria-labelledby="cargo-title" role="dialog">
  <div class="modal modal--sm">
    <div class="modal-header">
      <h2 class="modal-title" id="cargo-title">Nuevo cargo</h2>
      <button class="modal-close btn" data-modal-close aria-label="Cerrar">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="modal-body">
      <form id="form-cargo" novalidate>
        <div class="form-group" style="margin-bottom:0">
          <label class="form-label" for="cargo-nombre">
            Nombre del cargo <span class="required" aria-hidden="true">*</span>
          </label>
          <input class="form-input" type="text" id="cargo-nombre" maxlength="200"
                 placeholder="Ej. Regente de Farmacia" autocomplete="off" required>
        </div>
      </form>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" data-modal-close>Cancelar</button>
      <button class="btn btn-primary" id="btn-guardar-cargo">Crear cargo</button>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════
