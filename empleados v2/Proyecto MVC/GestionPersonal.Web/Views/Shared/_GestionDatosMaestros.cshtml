     ═══════════════════════════════════════════════════════════ -->
<div class="modal-overlay" id="modal-tipo-solicitud" hidden aria-modal="true"
     aria-labelledby="tipo-sol-title" role="dialog">
  <div class="modal modal--sm">
    <div class="modal-header">
      <h2 class="modal-title" id="tipo-sol-title">Nuevo tipo de solicitud</h2>
      <button class="modal-close btn" data-modal-close aria-label="Cerrar">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
