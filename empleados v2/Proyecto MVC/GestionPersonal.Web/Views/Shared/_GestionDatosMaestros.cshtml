    <div class="modal-body">
      <form id="form-tipo-solicitud" novalidate>
        <div class="form-group">
          <label class="form-label" for="tipo-sol-nombre">
            Nombre visible <span class="required" aria-hidden="true">*</span>
          </label>
          <input class="form-input" type="text" id="tipo-sol-nombre" maxlength="200"
                 placeholder="Ej. Permiso médico" autocomplete="off" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="tipo-sol-codigo">
            Código interno <span class="required" aria-hidden="true">*</span>
          </label>
          <input class="form-input" type="text" id="tipo-sol-codigo" maxlength="50"
                 placeholder="Ej. PermisoMedico" autocomplete="off" required
                 pattern="[A-Za-z0-9_]+" title="Solo letras, números y guión bajo">
          <p class="form-hint">Sin espacios. Es el valor que se guarda en cada solicitud.</p>
        </div>
        <label class="form-check" style="margin-bottom:0">
          <input type="checkbox" class="form-check-input" id="tipo-sol-es-vacaciones">
          <span class="form-check-label">Controla saldo de vacaciones (días a disfrutar)</span>
        </label>
      </form>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" data-modal-close>Cancelar</button>
      <button class="btn btn-primary" id="btn-guardar-tipo-solicitud">Crear tipo</button>
    </div>
  </div>
</div>

