@{
    var permisosModalPorModulo = Model.PermisosPlataforma
        .GroupBy(p => PermisosPlataformaTextos.Modulo(p.Codigo))
        .OrderBy(g => g.Key)
        .ToList();
}

<!-- ═══════════════════════════════════════════════════════════
     Modal: Rol del sistema (crear / editar)
     ═══════════════════════════════════════════════════════════ -->
<div class="modal-overlay" id="modal-rol" hidden aria-modal="true"
     aria-labelledby="rol-title" role="dialog">
  <div class="modal modal--lg">
    <div class="modal-header">
      <div class="modal-header-inner" style="flex-direction:column;align-items:flex-start;gap:0">
        <h2 class="modal-title" id="rol-title">Nuevo rol</h2>
        <p class="modal-subtitle--muted" id="rol-subtitle">Define el nombre y los permisos de acceso en la plataforma.</p>
      </div>
      <button class="modal-close btn" data-modal-close aria-label="Cerrar">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="modal-body">
      <form id="form-rol" novalidate>
        <div class="form-grid form-grid-2">
          <div class="form-group">
            <label class="form-label" for="rol-codigo">
              Código del rol <span class="required" aria-hidden="true">*</span>
            </label>
            <input class="form-input" type="text" id="rol-codigo" maxlength="50"
                   placeholder="Ej. CoordinadorRH" autocomplete="off" required />
            <p class="form-hint">Sin espacios. Coincide con el valor en <code>Usuarios.Rol</code>.</p>
          </div>
          <div class="form-group">
            <label class="form-label" for="rol-estado">Estado</label>
            <select class="form-select" id="rol-estado" disabled aria-describedby="rol-estado-hint">
              <option value="Activo">Activo</option>
              <option value="Inactivo">Inactivo</option>
            </select>
            <p class="form-hint" id="rol-estado-hint">Al crear, el rol queda activo.</p>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label" for="rol-nombre">
            Nombre visible <span class="required" aria-hidden="true">*</span>
          </label>
          <input class="form-input" type="text" id="rol-nombre" maxlength="200"
                 placeholder="Ej. Coordinador de recursos humanos" autocomplete="off" required />
        </div>
        <div class="form-group" style="margin-bottom:0">
          <label class="form-label" for="rol-descripcion">Descripción</label>
          <textarea class="form-input" id="rol-descripcion" maxlength="500" rows="2"
                    placeholder="Breve descripción del alcance del rol (opcional)"
                    style="resize:vertical;min-height:4.5rem"></textarea>
        </div>

        <section class="rol-permisos-section" aria-labelledby="rol-permisos-label">
          <div class="rol-permisos-head">
            <label class="form-label" id="rol-permisos-label">
              Permisos en la plataforma <span class="required" aria-hidden="true">*</span>
            </label>
            <div class="rol-permisos-actions">
              <button type="button" class="btn btn-ghost btn-sm" id="btn-permisos-todos">Seleccionar todos</button>
              <button type="button" class="btn btn-ghost btn-sm" id="btn-permisos-ninguno">Quitar todos</button>
            </div>
          </div>
          <div class="rol-permisos-panel" id="rol-permisos-container">
            @foreach (var grupo in permisosModalPorModulo)
            {
              <div class="rol-permisos-grupo">
                <h3 class="rol-permisos-grupo-titulo">@grupo.Key</h3>
                <div class="rol-permisos-lista">
                  @foreach (var p in grupo.OrderBy(x => x.Orden))
                  {
                    var desc = PermisosPlataformaTextos.Descripcion(p.Codigo);
                    <label class="form-check rol-permiso-item">
                      <input type="checkbox" class="permiso-check" value="@p.Id"
                             aria-describedby="permiso-desc-@p.Id" />
                      <span class="form-check-label">
                        <span class="rol-permiso-nombre">@PermisosPlataformaTextos.Nombre(p.Codigo)</span>
                        @if (!string.IsNullOrWhiteSpace(desc))
                        {
                          <span class="rol-permiso-desc" id="permiso-desc-@p.Id">@desc</span>
                        }
                        <code class="rol-permiso-codigo">@p.Codigo</code>
                      </span>
                    </label>
                  }
                </div>
              </div>
            }
          </div>
        </section>
      </form>
    </div>
    <div class="modal-footer">
      <button type="button" class="btn btn-secondary" data-modal-close>Cancelar</button>
      <button type="button" class="btn btn-primary" id="btn-guardar-rol">Crear rol</button>
    </div>
  </div>
</div>

<script>
(function () {
  'use strict';

  const TOKEN = '@antiforgery';

  /* ── Estado de edición (null = modo crear) ─────────── */
  let sedeEditId         = null;
  let cargoEditId        = null;
  let empresaEditId      = null;
  let tipoSolicitudEditId = null;
  let rolEditId          = null;

  /* ── Helper AJAX ────────────────────────────────────── */
  function postAjax(url, body, btn) {
    if (btn) { btn.disabled = true; btn.classList.add('btn-loading'); }
    const fd = new FormData();
    fd.append('__RequestVerificationToken', TOKEN);
    for (const [k, v] of Object.entries(body)) {
      if (Array.isArray(v)) {
        v.forEach((item, i) => fd.append(`${k}[${i}]`, item));
      } else {
        fd.append(k, v);
      }
    }
    return fetch(url, { method: 'POST', body: fd })
      .then(r => r.json())
      .finally(() => {
        if (btn) { btn.disabled = false; btn.classList.remove('btn-loading'); }
      });
  }

  function getPermisosSeleccionados() {
    return Array.from(document.querySelectorAll('#rol-permisos-container .permiso-check:checked'))
      .map(cb => parseInt(cb.value, 10));
  }

  function setPermisosSeleccionados(ids) {
    document.querySelectorAll('#rol-permisos-container .permiso-check').forEach(cb => {
      cb.checked = ids.includes(parseInt(cb.value, 10));
    });
  }

  function resetFormRol() {
    document.getElementById('rol-codigo').value = '';
    document.getElementById('rol-codigo').readOnly = false;
    document.getElementById('rol-nombre').value = '';
    document.getElementById('rol-descripcion').value = '';
    document.getElementById('rol-estado').value = 'Activo';
    document.getElementById('rol-estado').disabled = true;
    document.getElementById('rol-estado-hint').textContent = 'Al crear, el rol queda activo.';
    setPermisosSeleccionados([]);
  }

  window.abrirCrearRol = function () {
    rolEditId = null;
    document.getElementById('rol-title').textContent = 'Nuevo rol';
    document.getElementById('rol-subtitle').textContent = 'Define el nombre y los permisos de acceso en la plataforma.';
    document.getElementById('btn-guardar-rol').textContent = 'Crear rol';
    resetFormRol();
    openModal('modal-rol');
  };

  window.abrirEditarRol = function (id) {
    fetch('@Url.Action("ObtenerRolAjax", maestrosCtrl)?id=' + id)
      .then(r => r.json())
      .then(data => {
        if (!data.exito) { showToast(data.mensaje || 'No se pudo cargar el rol.', 'error'); return; }
        const d = data.datos;
        rolEditId = d.id;
        document.getElementById('rol-title').textContent = 'Editar rol';
        document.getElementById('rol-subtitle').textContent = 'Actualiza el nombre, estado y permisos del rol.';
        document.getElementById('btn-guardar-rol').textContent = 'Guardar cambios';
        document.getElementById('rol-codigo').value = d.codigo;
        document.getElementById('rol-codigo').readOnly = true;
        document.getElementById('rol-nombre').value = d.nombre;
        document.getElementById('rol-descripcion').value = d.descripcion || '';
        document.getElementById('rol-estado').value = d.estado;
        document.getElementById('rol-estado').disabled = false;
        document.getElementById('rol-estado-hint').textContent = 'Los roles inactivos no reciben permisos al iniciar sesión.';
        setPermisosSeleccionados(d.permisoIds || []);
        openModal('modal-rol');
      })
      .catch(() => showToast('Error de red.', 'error'));
  };

  function recargar(tab) {
    window.location.href = '@Url.Action("Index", maestrosCtrl)?tab=' + tab;
  }

  function confirmarBaja(nombre, tipoLabel) {
    return confirmAction({
      title: '¿Eliminar o dar de baja?',
      subtitle: 'Esta acción puede ser irreversible',
      itemType: tipoLabel,
      itemName: nombre,
      message: 'Si el registro está en uso por empleados o usuarios, se inactivará automáticamente y dejará de aparecer en los listados de asignación.',
      confirmLabel: 'Eliminar / Dar de baja',
      type: 'danger'
    });
  }

  function confirmarActivar(nombre, tipoLabel) {
    return confirmAction({
      title: '¿Activar registro?',
      subtitle: 'Volverá a estar disponible',
      itemType: tipoLabel,
      itemName: nombre,
      message: 'El registro aparecerá nuevamente en los listados de asignación al crear o editar empleados.',
      confirmLabel: 'Activar',
      type: 'primary'
    });
  }

  function ejecutarBaja(url, id, tab, btn) {
    postAjax(url, { id: id }, btn)
      .then(data => {
        if (data.exito) {
          showToast(data.mensaje || 'Operación realizada.', 'success');
          setTimeout(() => recargar(tab), 700);
        } else {
          showToast(data.mensaje || 'No se pudo completar la operación.', 'error');
        }
      })
      .catch(() => showToast('Error de red.', 'error'));
  }

  window.darDeBajaSede = async function (btn) {
    const id = parseInt(btn.dataset.id, 10);
    const nombre = btn.dataset.nombre || 'Sede sin nombre';
    if (!await confirmarBaja(nombre, 'Sede')) return;
    ejecutarBaja('@Url.Action("DarDeBajaSedeAjax", maestrosCtrl)', id, 'sedes', btn);
  };

  window.activarSede = async function (btn) {
    const id = parseInt(btn.dataset.id, 10);
    const nombre = btn.dataset.nombre || 'Sede';
    if (!await confirmarActivar(nombre, 'Sede')) return;
    ejecutarBaja('@Url.Action("ActivarSedeAjax", maestrosCtrl)', id, 'sedes', btn);
  };

  window.darDeBajaCargo = async function (btn) {
    const id = parseInt(btn.dataset.id, 10);
    const nombre = btn.dataset.nombre || 'Cargo sin nombre';
    if (!await confirmarBaja(nombre, 'Cargo')) return;
    ejecutarBaja('@Url.Action("DarDeBajaCargoAjax", maestrosCtrl)', id, 'cargos', btn);
  };

  window.activarCargo = async function (btn) {
    const id = parseInt(btn.dataset.id, 10);
    const nombre = btn.dataset.nombre || 'Cargo';
    if (!await confirmarActivar(nombre, 'Cargo')) return;
    ejecutarBaja('@Url.Action("ActivarCargoAjax", maestrosCtrl)', id, 'cargos', btn);
  };

  window.darDeBajaTipoSolicitud = async function (btn) {
    const id = parseInt(btn.dataset.id, 10);
    const nombre = btn.dataset.nombre || 'Tipo de solicitud';
    if (!await confirmarBaja(nombre, 'Tipo de solicitud')) return;
    ejecutarBaja('@Url.Action("DarDeBajaTipoSolicitudAjax", maestrosCtrl)', id, 'tipos-solicitud', btn);
  };

  window.activarTipoSolicitud = async function (btn) {
    const id = parseInt(btn.dataset.id, 10);
    const nombre = btn.dataset.nombre || 'Tipo de solicitud';
    if (!await confirmarActivar(nombre, 'Tipo de solicitud')) return;
    ejecutarBaja('@Url.Action("ActivarTipoSolicitudAjax", maestrosCtrl)', id, 'tipos-solicitud', btn);
  };

  window.darDeBajaEmpresa = async function (btn) {
    const id = parseInt(btn.dataset.id, 10);
    const nombre = btn.dataset.nombre || 'Empresa sin nombre';
    if (!await confirmarBaja(nombre, 'Empresa temporal')) return;
    ejecutarBaja('@Url.Action("DarDeBajaEmpresaAjax", maestrosCtrl)', id, 'empresas', btn);
  };

  window.activarEmpresa = async function (btn) {
    const id = parseInt(btn.dataset.id, 10);
    const nombre = btn.dataset.nombre || 'Empresa';
    if (!await confirmarActivar(nombre, 'Empresa temporal')) return;
    ejecutarBaja('@Url.Action("ActivarEmpresaAjax", maestrosCtrl)', id, 'empresas', btn);
  };

  window.darDeBajaRol = async function (btn) {
    const id = parseInt(btn.dataset.id, 10);
    const nombre = btn.dataset.nombre || 'Rol sin nombre';
    if (!await confirmarBaja(nombre, 'Rol del sistema')) return;
    ejecutarBaja('@Url.Action("DarDeBajaRolAjax", maestrosCtrl)', id, 'roles', btn);
  };

  window.activarRol = async function (btn) {
    const id = parseInt(btn.dataset.id, 10);
    const nombre = btn.dataset.nombre || 'Rol';
    if (!await confirmarActivar(nombre, 'Rol del sistema')) return;
    ejecutarBaja('@Url.Action("ActivarRolAjax", maestrosCtrl)', id, 'roles', btn);
  };

  /* ════════════════════════════════════════
     SEDES
     ════════════════════════════════════════ */
  window.abrirCrearSede = function () {
    sedeEditId = null;
    document.getElementById('form-sede').reset();
    document.getElementById('sede-title').textContent     = 'Nueva sede';
    document.getElementById('btn-guardar-sede').textContent = 'Crear sede';
    openModal('modal-sede');
  };

  window.abrirEditarSede = function (btn) {
    sedeEditId = parseInt(btn.dataset.id, 10);
    document.getElementById('sede-nombre').value    = btn.dataset.nombre    ?? '';
    document.getElementById('sede-ciudad').value    = btn.dataset.ciudad    ?? '';
    document.getElementById('sede-direccion').value = btn.dataset.direccion ?? '';
    document.getElementById('sede-title').textContent     = 'Editar sede';
    document.getElementById('btn-guardar-sede').textContent = 'Guardar cambios';
    openModal('modal-sede');
  };

  /* ════════════════════════════════════════
     CARGOS
     ════════════════════════════════════════ */
  window.abrirCrearCargo = function () {
    cargoEditId = null;
    document.getElementById('form-cargo').reset();
    document.getElementById('cargo-title').textContent     = 'Nuevo cargo';
    document.getElementById('btn-guardar-cargo').textContent = 'Crear cargo';
    openModal('modal-cargo');
  };

  window.abrirEditarCargo = function (btn) {
    cargoEditId = parseInt(btn.dataset.id, 10);
    document.getElementById('cargo-nombre').value = btn.dataset.nombre ?? '';
    document.getElementById('cargo-title').textContent     = 'Editar cargo';
    document.getElementById('btn-guardar-cargo').textContent = 'Guardar cambios';
    openModal('modal-cargo');
  };

  /* ════════════════════════════════════════
     EMPRESAS
     ════════════════════════════════════════ */
  window.abrirCrearTipoSolicitud = function () {
    tipoSolicitudEditId = null;
    document.getElementById('tipo-sol-title').textContent = 'Nuevo tipo de solicitud';
    document.getElementById('btn-guardar-tipo-solicitud').textContent = 'Crear tipo';
    document.getElementById('tipo-sol-nombre').value = '';
    document.getElementById('tipo-sol-codigo').value = '';
    document.getElementById('tipo-sol-codigo').readOnly = false;
    document.getElementById('tipo-sol-es-vacaciones').checked = false;
    openModal('modal-tipo-solicitud');
  };

  window.abrirEditarTipoSolicitud = function (btn) {
    tipoSolicitudEditId = btn.dataset.id;
    document.getElementById('tipo-sol-title').textContent = 'Editar tipo de solicitud';
    document.getElementById('btn-guardar-tipo-solicitud').textContent = 'Guardar cambios';
    document.getElementById('tipo-sol-nombre').value = btn.dataset.nombre || '';
    document.getElementById('tipo-sol-codigo').value = btn.dataset.codigo || '';
    document.getElementById('tipo-sol-codigo').readOnly = true;
    document.getElementById('tipo-sol-es-vacaciones').checked = btn.dataset.esVacaciones === '1';
    openModal('modal-tipo-solicitud');
  };

  window.abrirCrearEmpresa = function () {
    empresaEditId = null;
    document.getElementById('form-empresa').reset();
    document.getElementById('empresa-title').textContent     = 'Nueva empresa temporal';
    document.getElementById('btn-guardar-empresa').textContent = 'Crear empresa';
    openModal('modal-empresa');
  };

  window.abrirEditarEmpresa = function (btn) {
    empresaEditId = parseInt(btn.dataset.id, 10);
    document.getElementById('empresa-nombre').value = btn.dataset.nombre ?? '';
    document.getElementById('empresa-title').textContent     = 'Editar empresa temporal';
    document.getElementById('btn-guardar-empresa').textContent = 'Guardar cambios';
    openModal('modal-empresa');
  };

  /* ════════════════════════════════════════
     GUARDAR — se decide crear o editar por el estado del id
     ════════════════════════════════════════ */
  document.addEventListener('DOMContentLoaded', function () {

    /* — Sede — */
    document.getElementById('btn-guardar-sede')?.addEventListener('click', function () {
      const nombre    = (document.getElementById('sede-nombre')?.value    ?? '').trim();
      const ciudad    = (document.getElementById('sede-ciudad')?.value    ?? '').trim();
      const direccion = (document.getElementById('sede-direccion')?.value ?? '').trim();

      if (!nombre || !ciudad || !direccion) {
        showToast('Completa todos los campos obligatorios.', 'error'); return;
      }

      const esEditar = sedeEditId !== null;
      const url = esEditar
        ? '@Url.Action("EditarSedeAjax", maestrosCtrl)'
        : '@Url.Action("CrearSedeAjax", maestrosCtrl)';
      const body = esEditar
        ? { Id: sedeEditId, Nombre: nombre, Ciudad: ciudad, Direccion: direccion }
        : { Nombre: nombre, Ciudad: ciudad, Direccion: direccion };

      postAjax(url, body, this)
        .then(data => {
          if (data.exito) {
            showToast(data.mensaje || (esEditar ? 'Sede actualizada.' : 'Sede creada.'), 'success');
            closeModal('modal-sede');
            setTimeout(() => recargar('sedes'), 700);
          } else {
            showToast(data.mensaje || 'Error al guardar.', 'error');
          }
        })
        .catch(() => showToast('Error de red.', 'error'));
    });

    /* — Cargo — */
    document.getElementById('btn-guardar-cargo')?.addEventListener('click', function () {
      const nombre = (document.getElementById('cargo-nombre')?.value ?? '').trim();
      if (!nombre) { showToast('El nombre del cargo es obligatorio.', 'error'); return; }

      const esEditar = cargoEditId !== null;
      const url = esEditar
        ? '@Url.Action("EditarCargoAjax", maestrosCtrl)'
        : '@Url.Action("CrearCargoAjax", maestrosCtrl)';
      const body = esEditar ? { Id: cargoEditId, Nombre: nombre } : { Nombre: nombre };

      postAjax(url, body, this)
        .then(data => {
          if (data.exito) {
            showToast(data.mensaje || (esEditar ? 'Cargo actualizado.' : 'Cargo creado.'), 'success');
            closeModal('modal-cargo');
            setTimeout(() => recargar('cargos'), 700);
          } else {
            showToast(data.mensaje || 'Error al guardar.', 'error');
          }
        })
        .catch(() => showToast('Error de red.', 'error'));
    });

    /* — Tipo de solicitud — */
    document.getElementById('btn-guardar-tipo-solicitud')?.addEventListener('click', function () {
      const nombre = (document.getElementById('tipo-sol-nombre')?.value ?? '').trim();
      const codigo = (document.getElementById('tipo-sol-codigo')?.value ?? '').trim();
      const esVac  = document.getElementById('tipo-sol-es-vacaciones')?.checked ?? false;

      if (!nombre || !codigo) {
        showToast('Completa nombre y código.', 'error'); return;
      }
      if (!/^[A-Za-z0-9_]+$/.test(codigo)) {
        showToast('El código solo puede contener letras, números y guión bajo.', 'error'); return;
      }

      const esEditar = tipoSolicitudEditId !== null;
      const url = esEditar
        ? '@Url.Action("EditarTipoSolicitudAjax", maestrosCtrl)'
        : '@Url.Action("CrearTipoSolicitudAjax", maestrosCtrl)';
      const body = esEditar
        ? { Id: tipoSolicitudEditId, Nombre: nombre, EsVacaciones: esVac }
        : { Nombre: nombre, Codigo: codigo, EsVacaciones: esVac };

      postAjax(url, body, this)
        .then(data => {
          if (data.exito) {
            showToast(data.mensaje || 'Guardado correctamente.', 'success');
            closeModal('modal-tipo-solicitud');
            setTimeout(() => recargar('tipos-solicitud'), 700);
          } else {
            showToast(data.mensaje || 'Error al guardar.', 'error');
          }
        })
        .catch(() => showToast('Error de red.', 'error'));
    });

    /* — Empresa — */
    document.getElementById('btn-guardar-empresa')?.addEventListener('click', function () {
      const nombre = (document.getElementById('empresa-nombre')?.value ?? '').trim();
      if (!nombre) { showToast('El nombre de la empresa es obligatorio.', 'error'); return; }

      const esEditar = empresaEditId !== null;
      const url = esEditar
        ? '@Url.Action("EditarEmpresaAjax", maestrosCtrl)'
        : '@Url.Action("CrearEmpresaAjax", maestrosCtrl)';
      const body = esEditar ? { Id: empresaEditId, Nombre: nombre } : { Nombre: nombre };

      postAjax(url, body, this)
        .then(data => {
          if (data.exito) {
            showToast(data.mensaje || (esEditar ? 'Empresa actualizada.' : 'Empresa creada.'), 'success');
            closeModal('modal-empresa');
            setTimeout(() => recargar('empresas'), 700);
          } else {
            showToast(data.mensaje || 'Error al guardar.', 'error');
          }
        })
        .catch(() => showToast('Error de red.', 'error'));
    });

    document.getElementById('btn-permisos-todos')?.addEventListener('click', function () {
      document.querySelectorAll('#rol-permisos-container .permiso-check').forEach(cb => { cb.checked = true; });
    });
    document.getElementById('btn-permisos-ninguno')?.addEventListener('click', function () {
      document.querySelectorAll('#rol-permisos-container .permiso-check').forEach(cb => { cb.checked = false; });
    });

    document.getElementById('btn-guardar-rol')?.addEventListener('click', function () {
      const codigo = (document.getElementById('rol-codigo')?.value ?? '').trim();
      const nombre = (document.getElementById('rol-nombre')?.value ?? '').trim();
      const descripcion = (document.getElementById('rol-descripcion')?.value ?? '').trim();
      const permisoIds = getPermisosSeleccionados();
      if (!nombre) { showToast('El nombre del rol es obligatorio.', 'error'); return; }
      if (!rolEditId && !codigo) { showToast('El código del rol es obligatorio.', 'error'); return; }
      if (permisoIds.length === 0) { showToast('Selecciona al menos un permiso.', 'error'); return; }

      const esEditar = rolEditId !== null;
      const url = esEditar
        ? '@Url.Action("EditarRolAjax", maestrosCtrl)'
        : '@Url.Action("CrearRolAjax", maestrosCtrl)';
      const body = esEditar
        ? { Id: rolEditId, Nombre: nombre, Descripcion: descripcion, Estado: document.getElementById('rol-estado').value, PermisoIds: permisoIds }
        : { Codigo: codigo, Nombre: nombre, Descripcion: descripcion, PermisoIds: permisoIds };

      postAjax(url, body, this)
        .then(data => {
          if (data.exito) {
            showToast(data.mensaje || 'Rol guardado.', 'success');
            closeModal('modal-rol');
            setTimeout(() => recargar('roles'), 700);
          } else {
            showToast(data.mensaje || 'Error al guardar.', 'error');
          }
        })
        .catch(() => showToast('Error de red.', 'error'));
    });
  });
})();
</script>

