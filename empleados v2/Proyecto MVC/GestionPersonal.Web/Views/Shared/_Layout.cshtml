@{
    var ctrl       = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var correoUser = User.FindFirstValue(ClaimTypes.Email) ?? "";
    var rolStr     = User.FindFirstValue(ClaimTypes.Role)  ?? "";
    var sedeNombre = User.FindFirstValue("SedeNombre") ?? "";
    var avatarMap  = new Dictionary<string,string>
    {
        {"Jefe","JE"}, {"Regente","RE"}, {"AuxiliarRegente","AR"},
        {"Operario","OP"}, {"Administrador","AD"}
    };
    var rolLabel = rolStr switch
    {
        "Jefe"             => "Jefe de Sede",
        "Regente"          => "Regente",
        "AuxiliarRegente"  => "Auxiliar de Regente",
        "Operario"         => "Operario",
        "Administrador"    => "Administrador",
        _                  => rolStr
    };
    avatarMap.TryGetValue(rolStr, out var avatarText);
    avatarText ??= rolStr.Length >= 2 ? rolStr[..2].ToUpper() : "?";

    string NavClass(string controller) =>
        ctrl.Equals(controller, StringComparison.OrdinalIgnoreCase) ? "nav-link is-active" : "nav-link";
}
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#1e3a8a" />
  <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — GestiónRH" : "GestiónRH")</title>
  <link rel="stylesheet" href="~/css/main.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
</head>
<body>
<a class="skip-link" href="#main-content">Saltar al contenido principal</a>

<div class="app-layout">

  <!-- ── Sidebar ───────────────────────────────────────────── -->
  <aside class="app-sidebar" aria-label="Navegación principal">

    <div class="sidebar-brand">
      <div class="sidebar-logo" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
             fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
        </svg>
      </div>
      <div class="sidebar-brand-text">
        <div class="sidebar-brand-name">GestiónRH</div>
        <div class="sidebar-brand-sub">Adm. de Empleados</div>
      </div>
    </div>

    <nav class="sidebar-nav" aria-label="Menú principal">
      <span class="nav-section">Principal</span>

      @if (User.IsInRole("Jefe") || User.IsInRole("Administrador")
           || User.IsInRole("Regente") || User.IsInRole("AuxiliarRegente"))
      {
      <a asp-controller="Dashboard" asp-action="Index" class="@NavClass("Dashboard")" aria-label="Dashboard"
         aria-current="@(ctrl == "Dashboard" ? "page" : null)">
        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
        </svg>
        <span class="nav-text">Dashboard</span>
      </a>
      }

      @if (User.IsInRole("Operario"))
      {
      <a asp-controller="Empleado" asp-action="Perfil"
         asp-route-id="@User.FindFirstValue("EmpleadoId")"
         class="@NavClass("Empleado")"
         aria-current="@(ctrl == "Empleado" ? "page" : null)">
        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
        </svg>
        <span class="nav-text">Mi Perfil</span>
      </a>
      }
      else
      {
      <a asp-controller="Empleado" asp-action="Index" class="@NavClass("Empleado")"
         aria-current="@(ctrl == "Empleado" ? "page" : null)">
        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
        </svg>
        <span class="nav-text">Empleados</span>
      </a>
      }

      @if (!User.IsInRole("Operario"))
      {
      <span class="nav-section">Operaciones</span>

      <a asp-controller="EventoLaboral" asp-action="Index" class="@NavClass("EventoLaboral")"
         aria-current="@(ctrl == "EventoLaboral" ? "page" : null)">
        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        <span class="nav-text">Eventos Laborales</span>
      </a>

      <a asp-controller="Turno" asp-action="Index" class="@NavClass("Turno")"
         aria-current="@(ctrl == "Turno" ? "page" : null)">
        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
        <span class="nav-text">Horarios y Turnos</span>
      </a>
      }

      <a asp-controller="HoraExtra" asp-action="Index" class="@NavClass("HoraExtra")"
         aria-current="@(ctrl == "HoraExtra" ? "page" : null)">
        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
          <line x1="18" y1="5" x2="22" y2="9" stroke-width="2.5"/>
          <line x1="22" y1="5" x2="18" y2="9" stroke-width="2.5"/>
        </svg>
        <span class="nav-text">Horas Extras</span>
      </a>

      @if (User.IsInRole("Jefe") || User.IsInRole("Administrador"))
      {
      <span class="nav-section">Configuración</span>
      <a asp-controller="Catalogos" asp-action="Index" class="@NavClass("Catalogos")"
         aria-current="@(ctrl == "Catalogos" ? "page" : null)">
        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="3"/>
          <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>
        </svg>
        <span class="nav-text">Catálogos</span>
      </a>
      }
    </nav>

    <div class="sidebar-footer">
      <div class="sidebar-user">
        <div class="sidebar-avatar" aria-hidden="true">@avatarText</div>
        <div class="sidebar-user-info">
          <div class="sidebar-user-name" title="@correoUser">@correoUser</div>
          <div class="sidebar-user-role">@rolLabel</div>
        </div>
        <a asp-controller="Cuenta" asp-action="Logout" title="Cerrar sesión" aria-label="Cerrar sesión"
           style="color:rgba(255,255,255,0.45);flex-shrink:0;display:flex;align-items:center;">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
            <polyline points="16 17 21 12 16 7"/>
            <line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
        </a>
      </div>
    </div>
  </aside>

  <!-- ── Topbar ─────────────────────────────────────────────── -->
  <header class="app-topbar" role="banner">
    <div class="topbar-left">
      <nav aria-label="Ruta de navegación">
        <ol class="breadcrumb">
          @if (ViewData["BreadcrumbParent"] is string bcParent && ViewData["BreadcrumbParentUrl"] is string bcParentUrl)
          {
            <li class="breadcrumb-item">
              <a href="@bcParentUrl" class="bc-link">@bcParent</a>
              <span class="bc-sep" aria-hidden="true">/</span>
            </li>
          }
          <li class="breadcrumb-item">
            <span class="bc-current">@(ViewData["BreadcrumbCurrent"] ?? ViewData["Title"] ?? ctrl)</span>
          </li>
        </ol>
      </nav>
    </div>
    <div class="topbar-right" style="font-size:.8125rem;color:var(--c-gray-500)">
      @sedeNombre
    </div>
  </header>

  <!-- ── Main Content ───────────────────────────────────────── -->
  <main class="app-main" id="main-content">
    @RenderBody()
  </main>

</div>

<script src="~/js/app.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
