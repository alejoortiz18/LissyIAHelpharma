@using GestionPersonal.Constants
@using GestionPersonal.Web.Helpers
@{
    var ctrl       = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var correoUser = User.FindFirstValue(ClaimTypes.Email) ?? "";
    var esAnalista = User.IsInRole("Analista");
    var puedeMaestros = esAnalista;
    var maestrosController = "Catalogos";
    var puedeEmpleadosListado = PermisoHelper.TienePermiso(User, PermisosCodigo.EmpleadosVerListado);
    var puedePerfilPropio = PermisoHelper.TienePermiso(User, PermisosCodigo.EmpleadosVerPerfilPropio);
    var puedeSolicitudes = PermisoHelper.TienePermiso(User, PermisosCodigo.SolicitudesVer);
    var puedeEventos = PermisoHelper.TienePermiso(User, PermisosCodigo.EventosLaboralesVer);
    var puedeTurnos = PermisoHelper.TienePermiso(User, PermisosCodigo.TurnosVer);
    var puedeHorasExtras = PermisoHelper.TienePermiso(User, PermisosCodigo.HorasExtrasVer);
    var menuPersonal = puedePerfilPropio && !puedeEmpleadosListado;
    var puedeDashboard = PermisoHelper.TienePermiso(User, PermisosCodigo.DashboardVer);
    var rolStr     = User.FindFirstValue(ClaimTypes.Role) ?? "";
    var sedeNombre = User.FindFirstValue("SedeNombre") ?? "";
    var avatarMap  = new Dictionary<string,string>
    {
        {"DirectorTecnico","DT"}, {"Regente","RE"}, {"AuxiliarRegente","AR"},
        {"Operario","OP"}, {"Administrador","AD"}, {"Analista","AN"}, {"Direccionador","DI"}
    };
    var rolLabel = rolStr switch
    {
        "DirectorTecnico"  => "Director Técnico",
        "Regente"          => "Regente",
        "AuxiliarRegente"  => "Auxiliar de Regente",
        "Operario"         => "Operario",
        "Administrador"    => "Administrador",
        "Analista"         => "Analista",
        "Direccionador"    => "Direccionador",
        _                  => rolStr
    };
    avatarMap.TryGetValue(rolStr, out var avatarText);
    avatarText ??= rolStr.Length >= 2 ? rolStr[..2].ToUpper() : "?";

    string NavClass(string controller) =>
        ctrl.Equals(controller, StringComparison.OrdinalIgnoreCase) ? "nav-link is-active" : "nav-link";
}
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#1e3a8a" />
  <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — GestiónRH" : "GestiónRH")</title>
  <link rel="stylesheet" href="~/css/main.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
</head>
<body>
<a class="skip-link" href="#main-content">Saltar al contenido principal</a>

<div class="app-layout">

  <!-- ── Sidebar ───────────────────────────────────────────── -->
  <aside class="app-sidebar" aria-label="Navegación principal">

    <div class="sidebar-brand">
      <div class="sidebar-logo" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
             fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
        </svg>
      </div>
      <div class="sidebar-brand-text">
        <div class="sidebar-brand-name">GestiónRH</div>
        <div class="sidebar-brand-sub">Adm. de Empleados</div>
      </div>
    </div>

    <nav class="sidebar-nav" aria-label="Menú principal">
      <span class="nav-section">Principal</span>

      @if (puedeDashboard)
      {
      <a asp-controller="Dashboard" asp-action="Index" class="@NavClass("Dashboard")" aria-label="Dashboard"
         aria-current="@(ctrl == "Dashboard" ? "page" : null)">
        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
        </svg>
        <span class="nav-text">Dashboard</span>
      </a>
      }

      @if (User.IsInRole("Analista"))
      {
      <a asp-controller="Sedes" asp-action="Index" class="@NavClass("Sedes")"
         aria-current="@(ctrl == "Sedes" ? "page" : null)">
        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 21h18"/>
          <path d="M5 21V7l8-4 8 4v14"/>
          <path d="M9 21v-6h6v6"/>
        </svg>
        <span class="nav-text">Sedes</span>
      </a>
      }

      @if (menuPersonal)
      {
      <a asp-controller="Empleado" asp-action="Perfil"
         asp-route-id="@User.FindFirstValue("EmpleadoId")"
         class="@NavClass("Empleado")"
         aria-current="@(ctrl == "Empleado" ? "page" : null)">
        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
        </svg>
        <span class="nav-text">Mi Perfil</span>
      </a>

      @if (puedeSolicitudes)
      {
      <a asp-controller="Solicitud" asp-action="Index" class="@NavClass("Solicitud")"
         aria-current="@(ctrl == "Solicitud" ? "page" : null)">
        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="13" y2="17"/>
        </svg>
        <span class="nav-text">Mis Solicitudes</span>
      </a>
      }
      }
      @if (puedeEmpleadosListado)
      {
      <a asp-controller="Empleado" asp-action="Index" class="@NavClass("Empleado")"
         aria-current="@(ctrl == "Empleado" ? "page" : null)">
        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
        </svg>
        <span class="nav-text">Empleados</span>
      </a>
      }

      @if (puedeEventos || puedeTurnos)
      {
      <span class="nav-section">Operaciones</span>
      }

      @if (puedeEventos)
      {
      <a asp-controller="EventoLaboral" asp-action="Index" class="@NavClass("EventoLaboral")"
         aria-current="@(ctrl == "EventoLaboral" ? "page" : null)">
        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        <span class="nav-text">Eventos Laborales</span>
      </a>
      }

      @if (puedeTurnos)
      {
      <a asp-controller="Turno" asp-action="Index" class="@NavClass("Turno")"
         aria-current="@(ctrl == "Turno" ? "page" : null)">
        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
        <span class="nav-text">Horarios y Turnos</span>
      </a>
      }

      @if (puedeHorasExtras)
      {
      <a asp-controller="HoraExtra" asp-action="Index" class="@NavClass("HoraExtra")"
         aria-current="@(ctrl == "HoraExtra" ? "page" : null)">
        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
          <line x1="18" y1="5" x2="22" y2="9" stroke-width="2.5"/>
          <line x1="22" y1="5" x2="18" y2="9" stroke-width="2.5"/>
        </svg>
        <span class="nav-text">Horas Extras</span>
      </a>
      }

      @if (puedeMaestros)
      {
      <span class="nav-section">Configuración</span>
      <a asp-controller="@maestrosController" asp-action="Index" class="@NavClass(maestrosController)"
         aria-current="@(ctrl == maestrosController || ctrl == "Catalogos" || ctrl == "DatosMaestros" ? "page" : null)">
        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <ellipse cx="12" cy="5" rx="9" ry="3"/>
          <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/>
          <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
        </svg>
        <span class="nav-text">Maestros</span>
      </a>
      }
    </nav>

    <div class="sidebar-footer">
      <div class="sidebar-user">
        <div class="sidebar-avatar" aria-hidden="true">@avatarText</div>
        <div class="sidebar-user-info">
          <div class="sidebar-user-name" title="@correoUser">@correoUser</div>
          <div class="sidebar-user-role">@rolLabel</div>
        </div>
        <a asp-controller="Cuenta" asp-action="Logout" title="Cerrar sesión" aria-label="Cerrar sesión"
           style="color:rgba(255,255,255,0.45);flex-shrink:0;display:flex;align-items:center;">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
            <polyline points="16 17 21 12 16 7"/>
            <line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
        </a>
      </div>
    </div>
  </aside>

  <!-- ── Topbar ─────────────────────────────────────────────── -->
  <header class="app-topbar" role="banner">
    <div class="topbar-left">
      <nav aria-label="Ruta de navegación">
        <ol class="breadcrumb">
          @if (ViewData["BreadcrumbParent"] is string bcParent && ViewData["BreadcrumbParentUrl"] is string bcParentUrl)
          {
            <li class="breadcrumb-item">
              <a href="@bcParentUrl" class="bc-link">@bcParent</a>
              <span class="bc-sep" aria-hidden="true">/</span>
            </li>
          }
          <li class="breadcrumb-item">
            <span class="bc-current">@(ViewData["BreadcrumbCurrent"] ?? ViewData["Title"] ?? ctrl)</span>
          </li>
        </ol>
      </nav>
    </div>
    <div class="topbar-right" style="font-size:.8125rem;color:var(--c-gray-500)">
      @sedeNombre
    </div>
  </header>

  <!-- ── Main Content ───────────────────────────────────────── -->
  <main class="app-main" id="main-content">
    @RenderBody()
  </main>

</div>

<!-- Modal global de confirmación -->
<div class="modal-overlay" id="confirm-modal" hidden aria-modal="true" role="dialog" aria-labelledby="confirm-title">
  <div class="modal modal--sm modal--danger-confirm" id="confirm-modal-panel">
    <div class="modal-header">
      <div class="modal-header-inner">
        <span class="modal-danger-icon" id="confirm-icon-danger" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="3 6 5 6 21 6"/>
            <path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
            <line x1="10" y1="11" x2="10" y2="17"/>
            <line x1="14" y1="11" x2="14" y2="17"/>
          </svg>
        </span>
        <span class="modal-danger-icon modal-confirm-icon--primary" id="confirm-icon-primary" hidden aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
        </span>
        <div>
          <h2 class="modal-title" id="confirm-title">Confirmar acción</h2>
          <p class="modal-subtitle" id="confirm-subtitle"></p>
        </div>
      </div>
      <button type="button" class="modal-close btn" data-confirm-cancel aria-label="Cerrar">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="modal-body">
      <div class="confirm-item-card" id="confirm-item-wrap" hidden>
        <span class="confirm-item-type" id="confirm-item-type"></span>
        <p class="confirm-item-name" id="confirm-item-name"></p>
      </div>
      <p class="confirm-message" id="confirm-message"></p>
    </div>
    <div class="modal-footer">
      <button type="button" class="btn btn-secondary" data-confirm-cancel>Cancelar</button>
      <button type="button" class="btn btn-danger" id="confirm-btn">Confirmar</button>
    </div>
  </div>
</div>

<script src="~/js/app.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
