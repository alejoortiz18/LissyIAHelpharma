@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["BreadcrumbCurrent"] = "Dashboard";
}

<div class="page-header">
  <div class="page-header-info">
    <h1 class="page-title">Dashboard</h1>
    <p class="page-desc" id="dash-date">—</p>
  </div>
</div>

@if (TempData["Exito"] != null)
{
  <div class="alert alert--success" style="margin-bottom:var(--sp-4)" role="alert">@TempData["Exito"]</div>
}

<!-- KPI Cards -->
<div class="stats-grid" style="--cols:3;margin-bottom:var(--sp-6)" role="group" aria-label="Indicadores del personal">

  <div class="stat-card">
    <div class="stat-icon stat-icon--blue" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
        <circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 00-3-3.87"/>
        <path d="M16 3.13a4 4 0 010 7.75"/>
      </svg>
    </div>
    <div class="stat-body">
      <p class="stat-label">Empleados activos</p>
      <p class="stat-value tabular-nums">@Model.Kpis.EmpleadosActivos</p>
      <p class="stat-cta">
        @Model.Kpis.EmpleadosDirectos directos · @Model.Kpis.EmpleadosTemporales temporales
      </p>
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-icon stat-icon--amber" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="4" width="18" height="18" rx="2"/>
        <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
        <line x1="3" y1="10" x2="21" y2="10"/>
        <line x1="12" y1="14" x2="12" y2="18"/><line x1="10" y1="16" x2="14" y2="16"/>
      </svg>
    </div>
    <div class="stat-body">
      <p class="stat-label">No disponibles hoy</p>
      <p class="stat-value tabular-nums">@Model.Kpis.EmpleadosConNovedad</p>
      <p class="stat-cta">
        @Model.Kpis.EnVacaciones vac · @Model.Kpis.ConIncapacidad incap · @Model.Kpis.ConPermiso permisos
      </p>
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-icon stat-icon--green" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <polyline points="12 6 12 12 16 14"/>
      </svg>
    </div>
    <div class="stat-body">
      <p class="stat-label">Horas extras pendientes</p>
      <p class="stat-value tabular-nums">@Model.Kpis.HorasExtrasPendientes</p>
      <p class="stat-cta">@Model.Kpis.TotalHorasAprobadasEsteMes h aprobadas este mes</p>
    </div>
  </div>

</div>

<!-- Empleados no disponibles hoy -->
<div class="card" style="margin-bottom:var(--sp-5)">
  <div class="card-header">
    <h2 class="card-title">Empleados no disponibles hoy</h2>
    <a asp-controller="EventoLaboral" asp-action="Index" class="btn btn-ghost btn-sm">Ver todos los eventos</a>
  </div>
  @if (Model.NovedadesHoy.Count == 0)
  {
    <div class="card-body">
      <div class="empty-state">
        <p class="empty-title">Sin novedades</p>
        <p class="empty-desc">Todos los empleados están disponibles hoy.</p>
      </div>
    </div>
  }
  else
  {
    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th scope="col">Empleado</th>
            <th scope="col">Sede</th>
            <th scope="col">Tipo de novedad</th>
            <th scope="col">Período</th>
            <th scope="col">Estado</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var n in Model.NovedadesHoy)
          {
            <tr>
              <td>
                <a asp-controller="Empleado" asp-action="Perfil" asp-route-id="@n.EmpleadoId" class="table-link">
                  @n.EmpleadoNombre
                </a>
              </td>
              <td>@n.SedeNombre</td>
              <td>@Html.Raw(BadgeTipo(n.TipoNovedad))</td>
              <td class="tabular-nums" style="font-size:.8125rem">@n.Periodo</td>
              <td>@Html.Raw(BadgeEstado(n.Estado))</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }
</div>

<!-- Horas extras pendientes de aprobación -->
<div class="card">
  <div class="card-header">
    <h2 class="card-title">Horas extras pendientes de aprobación</h2>
    <a asp-controller="HoraExtra" asp-action="Index" class="btn btn-ghost btn-sm">Ir a horas extras</a>
  </div>
  @if (Model.HorasExtrasPendientes.Count == 0)
  {
    <div class="card-body">
      <div class="empty-state">
        <p class="empty-title">Sin solicitudes pendientes</p>
      </div>
    </div>
  }
  else
  {
    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th scope="col">Empleado</th>
            <th scope="col">Fecha</th>
            <th scope="col">Horas</th>
            <th scope="col">Motivo</th>
            <th scope="col"><span class="sr-only">Acciones</span></th>
          </tr>
        </thead>
        <tbody>
          @foreach (var h in Model.HorasExtrasPendientes)
          {
            <tr>
              <td>
                <a asp-controller="Empleado" asp-action="Perfil" asp-route-id="@h.EmpleadoId" class="table-link">
                  @h.EmpleadoNombre
                </a>
              </td>
              <td class="tabular-nums" style="font-size:.8125rem">@h.FechaTrabajada</td>
              <td class="tabular-nums">@h.CantidadHoras&nbsp;h</td>
              <td style="font-size:.8125rem;max-width:16rem;white-space:normal">@h.Motivo</td>
              <td>
                <a asp-controller="HoraExtra" asp-action="Index" class="btn btn-ghost btn-sm">Ver todas</a>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }
</div>

@section Scripts {
<script>
  (function () {
    var d = new Intl.DateTimeFormat('es-CO', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }).format(new Date());
    var el = document.getElementById('dash-date');
    if (el) el.textContent = d.charAt(0).toUpperCase() + d.slice(1);
  })();
</script>
}

@functions {
    string BadgeEstado(string estado) => estado.ToLower() switch
    {
        "activo"     => "<span class=\"badge badge--activo\"><span class=\"badge-dot\"></span>Activo</span>",
        "finalizado" => "<span class=\"badge badge--finalizado\"><span class=\"badge-dot\"></span>Finalizado</span>",
        "anulado"    => "<span class=\"badge badge--anulado\"><span class=\"badge-dot\"></span>Anulado</span>",
        _            => $"<span class=\"badge\">{System.Net.WebUtility.HtmlEncode(estado)}</span>",
    };
    string BadgeTipo(string tipo) => tipo.ToLower() switch
    {
        "vacaciones"  => "<span class=\"badge badge--vacaciones\">Vacaciones</span>",
        "incapacidad" => "<span class=\"badge badge--incapacidad\">Incapacidad</span>",
        "permiso"     => "<span class=\"badge badge--permiso\">Permiso</span>",
        _             => $"<span class=\"badge\">{System.Net.WebUtility.HtmlEncode(tipo)}</span>",
    };
}

