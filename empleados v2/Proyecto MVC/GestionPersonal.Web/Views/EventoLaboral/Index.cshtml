@model EventosViewModel
@using GestionPersonal.Models.Enums
@using GestionPersonal.Web.Helpers
@{
    ViewData["Title"] = "Eventos laborales";
    ViewData["BreadcrumbCurrent"] = "Eventos laborales";
    var rol = SesionHelper.GetRol(User);
    bool puedeRegistrar = rol != RolUsuario.Operario;
    bool puedeGestionar = rol == RolUsuario.Regente ||
                          rol == RolUsuario.AuxiliarRegente ||
                          rol == RolUsuario.DirectorTecnico ||
                          rol == RolUsuario.Analista;
    var antiforgery = ViewContext.HttpContext.RequestServices
        .GetRequiredService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>()
        .GetAndStoreTokens(ViewContext.HttpContext).RequestToken;
}

<style>
  .ev-combo-active { background: var(--color-primary-light, #eff6ff); }
  #ev-empleado-list [role="option"]:hover { background: var(--color-primary-light, #eff6ff); }
</style>
<div class="page-header">
  <div class="page-header-info">
    <h1 class="page-title">Eventos Laborales</h1>
    <p class="page-desc">Vacaciones, incapacidades y permisos de los empleados de la sede.</p>
  </div>
  @if (puedeRegistrar)
  {
    <div class="page-actions">
      <button class="btn btn-primary" data-modal-open="modal-nuevo-evento">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Registrar evento
      </button>
    </div>
  }
</div>

@if (TempData["Exito"] != null)
{
  <div class="alert alert--success alert-dismissible" role="alert">@TempData["Exito"]</div>
}
@if (TempData["Error"] != null)
{
  <div class="alert alert--error alert-dismissible" role="alert">@TempData["Error"]</div>
}

<!-- Filtros -->
<form method="get" class="filter-bar" role="search" aria-label="Filtros de eventos">
  <input name="buscar" type="search" class="form-input filter-search"
         placeholder="Buscar empleado…" value="@Model.Buscar" autocomplete="off" aria-label="Buscar por empleado" />
  <select name="tipo" class="form-select" aria-label="Tipo de evento">
    <option value="">Todos los tipos</option>
    <option value="Vacaciones" selected="@(Model.Tipo == "Vacaciones")">Vacaciones</option>
    <option value="Incapacidad" selected="@(Model.Tipo == "Incapacidad")">Incapacidad</option>
    <option value="Permiso" selected="@(Model.Tipo == "Permiso")">Permiso</option>
  </select>
  <select name="estado" class="form-select" aria-label="Estado del evento">
    <option value="">Todos los estados</option>
    <option value="Pendiente"   selected="@(Model.Estado == "Pendiente")">Pendiente</option>
    <option value="Aprobado"    selected="@(Model.Estado == "Aprobado")">Aprobado</option>
    <option value="Rechazado"   selected="@(Model.Estado == "Rechazado")">Rechazado</option>
    <option value="EnRevision"  selected="@(Model.Estado == "EnRevision")">En revisión</option>
    <option value="Activo"      selected="@(Model.Estado == "Activo")">Activo</option>
    <option value="Finalizado"  selected="@(Model.Estado == "Finalizado")">Finalizado</option>
    <option value="Anulado"     selected="@(Model.Estado == "Anulado")">Anulado</option>
  </select>
  <input name="desde" type="date" class="form-input" value="@Model.Desde" aria-label="Desde fecha" />
  <input name="hasta" type="date" class="form-input" value="@Model.Hasta" aria-label="Hasta fecha" />
  <button type="submit" class="btn btn-secondary btn-sm">Filtrar</button>
  @if (!string.IsNullOrEmpty(Model.Buscar) || !string.IsNullOrEmpty(Model.Tipo) ||
       !string.IsNullOrEmpty(Model.Estado) || !string.IsNullOrEmpty(Model.Desde) ||
       !string.IsNullOrEmpty(Model.Hasta))
  {
    <a asp-action="Index" class="btn btn-ghost btn-sm">Limpiar</a>
  }
</form>

<!-- Tabla -->
@if (!Model.Eventos.Any())
{
  <div class="table-wrapper">
    <div class="empty-state">
      <div class="empty-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
      </div>
      <p class="empty-title">Sin eventos</p>
      <p class="empty-desc">No se encontraron eventos con los filtros seleccionados.</p>
    </div>
  </div>
}
else
{
  <div class="table-wrapper">
    <div class="table-scroll">
      <table aria-label="Eventos laborales">
        <thead>
          <tr>
            <th scope="col">Empleado</th>
            <th scope="col">Sede</th>
            <th scope="col">Tipo</th>
            <th scope="col">Período</th>
            <th scope="col">Días/Info</th>
            <th scope="col">Autorizado por</th>
            <th scope="col">Estado</th>
              @if (puedeRegistrar)
            {
              <th scope="col"><span class="sr-only">Acciones</span></th>
            }
          </tr>
        </thead>
        <tbody>
          @foreach (var ev in Model.Eventos)
          {
            <tr>
              <td>
                <a asp-controller="Empleado" asp-action="Perfil" asp-route-id="@ev.EmpleadoId"
                   asp-route-tab="historial" class="table-link">@ev.EmpleadoNombre</a>
              </td>
              <td>@ev.SedeNombre</td>
              <td>@Html.Raw(BadgeTipo(ev.TipoEvento))</td>
              <td class="tabular-nums" style="font-size:.8125rem;white-space:nowrap">
                @ev.FechaInicio → @ev.FechaFin
              </td>
              <td style="font-size:.8125rem;max-width:10rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                @if (ev.TipoEvento == "Vacaciones")
                {
                  @($"{ev.DiasSolicitados} días")
                }
                else if (!string.IsNullOrEmpty(ev.TipoIncapacidad))
                {
                  @ev.TipoIncapacidad
                }
                else if (!string.IsNullOrEmpty(ev.Descripcion))
                {
                  @(ev.Descripcion.Length > 30 ? ev.Descripcion[..30] + "…" : ev.Descripcion)
                }
                else
                {
                  <text>—</text>
                }
              </td>
              <td style="font-size:.8125rem">@ev.AutorizadoPor</td>
              <td>@Html.Raw(BadgeEstado(ev.Estado))</td>
              @if (puedeRegistrar)
              {
                <td>
                  @if (ev.Estado == "Activo")
                  {
                    <button class="btn btn-ghost btn-sm"
                            onclick="iniciarAnular(@ev.Id)"
                            aria-label="Anular evento">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
                      </svg>
                      Anular
                    </button>
                  }
                  @if (puedeGestionar && (ev.Estado == "Pendiente" || ev.Estado == "Aprobado" || ev.Estado == "Rechazado"))
                  {
                    <button class="btn btn-secondary btn-sm"
                            onclick="iniciarGestion(@ev.Id, '@ev.Estado')"
                            aria-label="Gestionar solicitud">
                      Gestionar
                    </button>
                  }
                </td>
              }
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div>

  @if (Model.TotalPaginas > 1)
  {
    <div class="pagination">
      <span class="pagination-info">Página @Model.Pagina de @Model.TotalPaginas</span>
      <div class="pagination-controls">
        @if (Model.Pagina > 1)
        {
          <a asp-action="Index" asp-route-buscar="@Model.Buscar" asp-route-tipo="@Model.Tipo"
             asp-route-estado="@Model.Estado" asp-route-desde="@Model.Desde" asp-route-hasta="@Model.Hasta"
             asp-route-pagina="@(Model.Pagina - 1)" class="page-btn">&#8249;</a>
        }
        @for (int p = 1; p <= Model.TotalPaginas; p++)
        {
          <a asp-action="Index" asp-route-buscar="@Model.Buscar" asp-route-tipo="@Model.Tipo"
             asp-route-estado="@Model.Estado" asp-route-desde="@Model.Desde" asp-route-hasta="@Model.Hasta"
             asp-route-pagina="@p" class="page-btn @(p == Model.Pagina ? "is-active" : "")">@p</a>
        }
        @if (Model.Pagina < Model.TotalPaginas)
        {
          <a asp-action="Index" asp-route-buscar="@Model.Buscar" asp-route-tipo="@Model.Tipo"
             asp-route-estado="@Model.Estado" asp-route-desde="@Model.Desde" asp-route-hasta="@Model.Hasta"
             asp-route-pagina="@(Model.Pagina + 1)" class="page-btn">&#8250;</a>
        }
      </div>
    </div>
  }
}

<!-- ═══════════════════════════════════════════════════════════
     Modal: Registrar evento laboral
     ═══════════════════════════════════════════════════════════ -->
@if (puedeRegistrar)
{
<div class="modal-overlay" id="modal-nuevo-evento" hidden aria-modal="true"
     aria-labelledby="modal-evento-title" role="dialog">
  <div class="modal modal--lg">
    <div class="modal-header">
      <h2 class="modal-title" id="modal-evento-title">Registrar evento laboral</h2>
      <button class="modal-close btn" data-modal-close aria-label="Cerrar">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="modal-body">
      <form id="form-evento" novalidate>
        <div class="form-grid form-grid-2" style="margin-bottom:var(--sp-4)">
          <div class="form-group" style="margin-bottom:0">
            <label class="form-label" for="ev-empleado-search">Empleado <span class="required" aria-hidden="true">*</span></label>
            <div class="ev-combobox" style="position:relative">
              <input class="form-input" type="text" id="ev-empleado-search"
                     autocomplete="off" spellcheck="false"
                     placeholder="Escribe nombre o cédula para buscar…"
                     aria-autocomplete="list" aria-controls="ev-empleado-list"
                     aria-expanded="false" role="combobox" />
              <input type="hidden" id="ev-empleado" name="EmpleadoId" />
              <ul id="ev-empleado-list" role="listbox"
                  style="display:none;position:absolute;z-index:999;left:0;right:0;top:100%;
                         background:var(--color-surface,#fff);border:1px solid var(--color-border,#d1d5db);
                         border-radius:var(--radius,0.375rem);margin-top:2px;
                         max-height:220px;overflow-y:auto;padding:0;list-style:none;
                         box-shadow:0 4px 12px rgba(0,0,0,.1)">
              </ul>
            </div>
          </div>
          <div class="form-group" style="margin-bottom:0">
            <label class="form-label" for="ev-tipo">Tipo de evento <span class="required" aria-hidden="true">*</span></label>
            <select class="form-select" id="ev-tipo" name="TipoEvento" required>
              <option value="">Selecciona tipo…</option>
              <option value="Vacaciones">Vacaciones</option>
              <option value="Incapacidad">Incapacidad</option>
              <option value="Permiso">Permiso</option>
            </select>
          </div>
        </div>

        <!-- Vacation balance widget -->
        <div id="vac-balance-widget" hidden>
          <div class="vac-balance" aria-live="polite">
            <div class="vac-balance-row">
              <span class="vac-balance-label">Días acumulados</span>
              <span class="vac-balance-val" id="vac-acumulados">—</span>
            </div>
            <div class="vac-balance-row">
              <span class="vac-balance-label">Días tomados</span>
              <span class="vac-balance-val" id="vac-tomados">—</span>
            </div>
            <div class="vac-balance-row" style="margin-bottom:var(--sp-3)">
              <span class="vac-balance-label" style="font-weight:700">Saldo disponible</span>
              <span class="vac-balance-val" id="vac-disponibles" style="font-size:1.125rem">—</span>
            </div>
            <div class="vac-bar-track" aria-hidden="true">
              <div class="vac-bar-fill" id="vac-bar" style="width:0%"></div>
            </div>
          </div>
          <div class="alert alert--error" id="vac-sin-saldo" hidden role="alert">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <div class="alert-body"><p class="alert-title">Saldo insuficiente</p><p>El empleado no tiene días disponibles para el período solicitado.</p></div>
          </div>
        </div>

        <div class="form-grid form-grid-2">
          <div class="form-group">
            <label class="form-label" for="ev-inicio">Fecha inicio <span class="required" aria-hidden="true">*</span></label>
            <input class="form-input" type="date" id="ev-inicio" name="FechaInicio" required>
          </div>
          <div class="form-group">
            <label class="form-label" for="ev-fin">Fecha fin <span class="required" aria-hidden="true">*</span></label>
            <input class="form-input" type="date" id="ev-fin" name="FechaFin" required>
          </div>
          <div class="form-group" id="campo-dias" hidden>
            <label class="form-label" for="ev-dias-calc">Días solicitados</label>
            <input class="form-input" type="text" id="ev-dias-calc" readonly aria-readonly="true" value="—">
            <span class="form-hint">Calculado automáticamente (excluye domingos).</span>
          </div>
        </div>

        <!-- Incapacidad fields -->
        <div id="campos-incapacidad" hidden>
          <div class="form-grid form-grid-2">
            <div class="form-group">
              <label class="form-label" for="ev-tipo-incap">Tipo de incapacidad <span class="required" aria-hidden="true">*</span></label>
              <select class="form-select" id="ev-tipo-incap" name="TipoIncapacidad">
                <option value="">Selecciona tipo…</option>
                <option value="EnfermedadGeneral">Enfermedad general</option>
                <option value="AccidenteTrabajo">Accidente de trabajo</option>
                <option value="EnfermedadLaboral">Enfermedad laboral</option>
                <option value="MaternidadPaternidad">Maternidad/Paternidad</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="ev-entidad">Entidad que expide <span class="required" aria-hidden="true">*</span></label>
              <input class="form-input" type="text" id="ev-entidad" name="EntidadExpide" autocomplete="off" placeholder="Nombre de la EPS o ARL…">
            </div>
          </div>
        </div>

        <!-- Permiso fields -->
        <div id="campos-permiso" hidden>
          <div class="form-group">
            <label class="form-label" for="ev-descripcion">Descripción / justificación <span class="required" aria-hidden="true">*</span></label>
            <textarea class="form-textarea" id="ev-descripcion" name="Descripcion" placeholder="Motivo del permiso…" style="min-height:4rem"></textarea>
          </div>
        </div>

        <!-- Common -->
        <div class="form-grid form-grid-2">
          <div class="form-group" style="margin-bottom:0">
            <label class="form-label" for="ev-autorizante">Autorizado por <span class="required" aria-hidden="true">*</span></label>
            <input class="form-input" type="text" id="ev-autorizante" name="AutorizadoPor" autocomplete="off" placeholder="Nombre de quien autoriza…" required>
          </div>
          <div class="form-group" style="margin-bottom:0">
            <label class="form-label" for="ev-documento">Documento de soporte</label>
            <input class="form-input" type="file" id="ev-documento" name="Documento"
                   accept=".pdf,.jpg,.jpeg,.png" style="padding-top:.375rem">
            <span class="form-hint" id="doc-hint">Opcional — PDF, JPG o PNG (máx. 5 MB).</span>
          </div>
        </div>

        <div class="alert alert--info" style="margin-top:var(--sp-4)" role="note">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
          </svg>
          <div class="alert-body">
            <p>El sistema verificará que el empleado no tenga otro evento activo en el mismo rango de fechas antes de guardar.</p>
          </div>
        </div>
      </form>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" data-modal-close>Cancelar</button>
      <button class="btn btn-primary" id="btn-guardar-evento">Registrar evento</button>
    </div>
  </div>
</div>

<!-- Modal: Anular evento -->
<div class="modal-overlay" id="modal-anular" hidden aria-modal="true"
     aria-labelledby="anular-title" role="dialog">
  <div class="modal modal--sm">
    <div class="modal-header">
      <h2 class="modal-title" id="anular-title">Anular evento</h2>
      <button class="modal-close btn" data-modal-close aria-label="Cerrar">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="modal-body">
      <div class="form-group" style="margin-bottom:0">
        <label class="form-label" for="motivo-anulacion">Motivo de anulación <span class="required" aria-hidden="true">*</span></label>
        <textarea class="form-textarea" id="motivo-anulacion"
                  placeholder="Describe el motivo de la anulación…" style="min-height:4rem"></textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" data-modal-close>Cancelar</button>
      <button class="btn btn-danger" id="btn-confirmar-anulacion">Anular evento</button>
    </div>
  </div>
</div>
}

<!-- Modal: Gestionar solicitud (aprobar / rechazar / reversar) -->
@if (puedeGestionar)
{
<div class="modal-overlay" id="modal-gestion" hidden aria-modal="true"
     aria-labelledby="gestion-title" role="dialog">
  <div class="modal modal--sm">
    <div class="modal-header">
      <h2 class="modal-title" id="gestion-title">Gestionar solicitud</h2>
      <button class="modal-close btn" data-modal-close aria-label="Cerrar">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label" for="gest-nuevo-estado">Nueva decisión <span class="required" aria-hidden="true">*</span></label>
        <select class="form-select" id="gest-nuevo-estado"></select>
      </div>
      <div class="form-group" id="gest-obs-group" style="margin-bottom:0">
        <label class="form-label" for="gest-observacion">Observación <span class="required" aria-hidden="true" id="gest-obs-required">*</span></label>
        <textarea class="form-textarea" id="gest-observacion"
                  placeholder="Escribe una observación…" style="min-height:4rem"></textarea>
        <span class="form-hint" id="gest-obs-hint">Obligatoria al rechazar o reversar una decisión.</span>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" data-modal-close>Cancelar</button>
      <button class="btn btn-primary" id="btn-confirmar-gestion">Confirmar</button>
    </div>
  </div>
</div>
}
<script>
(function () {
  'use strict';

  var anularEventoId = null;
  var vacSaldo = null;                      // cached balance for current employee/type

  /* ── Helpers ─────────────────────────────────────────────── */
  function calcDiasHabiles(inicio, fin) {
    if (!inicio || !fin) return 0;
    var d   = new Date(inicio + 'T12:00:00');
    var end = new Date(fin   + 'T12:00:00');
    var count = 0;
    while (d <= end) {
      if (d.getDay() !== 0) count++;        // exclude Sundays
      d.setDate(d.getDate() + 1);
    }
    return count;
  }

  function getToken() {
    var meta = document.querySelector('meta[name="__RequestVerificationToken"]');
    if (meta) return meta.getAttribute('content');
    var input = document.querySelector('input[name="__RequestVerificationToken"]');
    return input ? input.value : '@antiforgery';
  }

  /* ── Employee combobox ────────────────────────────────────── */
  (function () {
    var searchInput  = document.getElementById('ev-empleado-search');
    var hiddenInput  = document.getElementById('ev-empleado');
    var listBox      = document.getElementById('ev-empleado-list');
    var debounceTimer = null;
    var activeIndex  = -1;

    function openList() {
      listBox.style.display = 'block';
      searchInput.setAttribute('aria-expanded', 'true');
    }
    function closeList() {
      listBox.style.display = 'none';
      searchInput.setAttribute('aria-expanded', 'false');
      activeIndex = -1;
    }
    function setActive(idx) {
      var items = listBox.querySelectorAll('[role="option"]');
      items.forEach(function (el, i) {
        el.setAttribute('aria-selected', i === idx ? 'true' : 'false');
        el.classList.toggle('ev-combo-active', i === idx);
      });
      activeIndex = idx;
    }
    function selectItem(id, texto) {
      hiddenInput.value    = id;
      searchInput.value    = texto;
      closeList();
      updateVacBalance();
    }
    function renderItems(items) {
      listBox.innerHTML = '';
      if (!items.length) {
        var li = document.createElement('li');
        li.style.cssText = 'padding:.5rem .75rem;color:var(--color-muted,#6b7280);font-size:.875rem';
        li.textContent = 'Sin resultados';
        listBox.appendChild(li);
        openList();
        return;
      }
      items.forEach(function (item) {
        var li = document.createElement('li');
        li.setAttribute('role', 'option');
        li.setAttribute('aria-selected', 'false');
        li.setAttribute('data-id', item.id);
        li.setAttribute('data-texto', item.texto);
        li.style.cssText = 'padding:.5rem .75rem;cursor:pointer;font-size:.875rem';
        li.textContent = item.texto;
        li.addEventListener('mousedown', function (e) {
          e.preventDefault();
          selectItem(item.id, item.texto);
        });
        li.addEventListener('mouseover', function () {
          var all = listBox.querySelectorAll('[role="option"]');
          setActive(Array.from(all).indexOf(li));
        });
        listBox.appendChild(li);
      });
      openList();
    }
    function doSearch(q) {
      fetch('@Url.Action("BuscarEmpleados", "EventoLaboral")?q=' + encodeURIComponent(q))
        .then(function (r) { return r.ok ? r.json() : []; })
        .then(function (data) { renderItems(data); })
        .catch(function () { closeList(); });
    }

    searchInput.addEventListener('input', function () {
      hiddenInput.value = '';           // clear selection when user types
      var q = this.value.trim();
      clearTimeout(debounceTimer);
      if (q.length < 2) { closeList(); return; }
      debounceTimer = setTimeout(function () { doSearch(q); }, 300);
    });

    searchInput.addEventListener('keydown', function (e) {
      var items = listBox.querySelectorAll('[role="option"]');
      if (!items.length) return;
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        setActive(Math.min(activeIndex + 1, items.length - 1));
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        setActive(Math.max(activeIndex - 1, 0));
      } else if (e.key === 'Enter' && activeIndex >= 0) {
        e.preventDefault();
        var item = items[activeIndex];
        selectItem(item.getAttribute('data-id'), item.getAttribute('data-texto'));
      } else if (e.key === 'Escape') {
        closeList();
      }
    });

    document.addEventListener('click', function (e) {
      if (!e.target.closest('.ev-combobox')) closeList();
    });
  }());

  /* ── Vacation balance ─────────────────────────────────────── */
  function updateVacBalance() {
    var empId = document.getElementById('ev-empleado').value;
    var tipo  = document.getElementById('ev-tipo').value;
    var widget = document.getElementById('vac-balance-widget');

    if (!empId || tipo !== 'Vacaciones') {
      widget.hidden = true;
      vacSaldo = null;
      updateDiasCalc();
      return;
    }

    fetch('@Url.Action("SaldoVacaciones", "EventoLaboral")?empleadoId=' + encodeURIComponent(empId))
      .then(function (r) { return r.ok ? r.json() : null; })
      .then(function (data) {
        if (!data) { widget.hidden = true; vacSaldo = null; return; }
        vacSaldo = data;
        document.getElementById('vac-acumulados').textContent  = data.acumulados + ' días';
        document.getElementById('vac-tomados').textContent     = data.tomados    + ' días';
        document.getElementById('vac-disponibles').textContent = data.disponibles + ' días';
        var pct = data.acumulados > 0 ? Math.min(100, (data.disponibles / data.acumulados) * 100) : 0;
        var bar = document.getElementById('vac-bar');
        bar.style.width = pct + '%';
        bar.className   = 'vac-bar-fill' + (pct <= 20 ? ' is-empty' : pct <= 40 ? ' is-low' : '');
        widget.hidden = false;
        updateDiasCalc();
      })
      .catch(function () { widget.hidden = true; vacSaldo = null; });
  }

  function updateDiasCalc() {
    var inicio = document.getElementById('ev-inicio').value;
    var fin    = document.getElementById('ev-fin').value;
    var tipo   = document.getElementById('ev-tipo').value;
    var campo  = document.getElementById('campo-dias');
    var sinSaldo = document.getElementById('vac-sin-saldo');

    if (tipo === 'Vacaciones' && inicio && fin) {
      var dias = calcDiasHabiles(inicio, fin);
      document.getElementById('ev-dias-calc').value = dias + ' día' + (dias !== 1 ? 's' : '') + ' hábiles';
      campo.hidden = false;
      sinSaldo.hidden = !vacSaldo || dias <= vacSaldo.disponibles;
    } else {
      campo.hidden = true;
      if (sinSaldo) sinSaldo.hidden = true;
    }
  }

  /* ── Reset modal ──────────────────────────────────────────── */
  function resetModal() {
    document.getElementById('form-evento').reset();
    document.getElementById('ev-empleado-search').value   = '';
    document.getElementById('ev-empleado').value          = '';
    document.getElementById('vac-balance-widget').hidden   = true;
    document.getElementById('campos-incapacidad').hidden   = true;
    document.getElementById('campos-permiso').hidden       = true;
    document.getElementById('campo-dias').hidden           = true;
    document.getElementById('vac-sin-saldo').hidden        = true;
    document.getElementById('doc-hint').textContent        = 'Opcional — PDF, JPG o PNG (máx. 5 MB).';
    vacSaldo = null;
  }

  /* ── Event type toggle ────────────────────────────────────── */
  document.getElementById('ev-tipo').addEventListener('change', function () {
    document.getElementById('campos-incapacidad').hidden = this.value !== 'Incapacidad';
    document.getElementById('campos-permiso').hidden     = this.value !== 'Permiso';
    document.getElementById('doc-hint').textContent = this.value === 'Incapacidad'
      ? 'Requerido — certificado médico (PDF, JPG o PNG, máx. 5 MB).'
      : 'Opcional — PDF, JPG o PNG (máx. 5 MB).';
    updateVacBalance();
  });

  document.getElementById('ev-inicio').addEventListener('change', updateDiasCalc);
  document.getElementById('ev-fin').addEventListener('change', updateDiasCalc);

  /* ── Save event via AJAX ──────────────────────────────────── */
  document.getElementById('btn-guardar-evento').addEventListener('click', function () {
    var empId      = document.getElementById('ev-empleado').value;
    var tipo       = document.getElementById('ev-tipo').value;
    var inicio     = document.getElementById('ev-inicio').value;
    var fin        = document.getElementById('ev-fin').value;
    var autorizante = document.getElementById('ev-autorizante').value.trim();

    if (!empId || !tipo || !inicio || !fin || !autorizante) {
      showToast('Completa todos los campos obligatorios.', 'error'); return;
    }
    if (tipo === 'Vacaciones' && vacSaldo !== null) {
      var dias = calcDiasHabiles(inicio, fin);
      if (dias > vacSaldo.disponibles) {
        showToast('Saldo de vacaciones insuficiente.', 'error'); return;
      }
    }

    var form = document.getElementById('form-evento');
    var data = new FormData(form);

    fetch('@Url.Action("RegistrarAjax", "EventoLaboral")', {
      method: 'POST',
      headers: { 'RequestVerificationToken': getToken() },
      body: data
    })
    .then(function (r) { return r.json(); })
    .then(function (res) {
      if (res.exito) {
        closeModal('modal-nuevo-evento');
        resetModal();
        showToast('Evento registrado correctamente.', 'success');
        setTimeout(function () { window.location.reload(); }, 1200);
      } else {
        showToast(res.mensaje || 'No se pudo registrar el evento.', 'error');
      }
    })
    .catch(function () { showToast('Error de conexión. Intenta nuevamente.', 'error'); });
  });

  /* ── Anular via AJAX ──────────────────────────────────────── */
  window.iniciarAnular = function (id) {
    anularEventoId = id;
    document.getElementById('motivo-anulacion').value = '';
    openModal('modal-anular');
  };

  document.getElementById('btn-confirmar-anulacion').addEventListener('click', function () {
    var motivo = document.getElementById('motivo-anulacion').value.trim();
    if (!motivo) { showToast('El motivo es obligatorio.', 'error'); return; }

    var data = new FormData();
    data.append('id', anularEventoId);
    data.append('motivoAnulacion', motivo);

    fetch('@Url.Action("AnularAjax", "EventoLaboral")', {
      method: 'POST',
      headers: { 'RequestVerificationToken': getToken() },
      body: data
    })
    .then(function (r) { return r.json(); })
    .then(function (res) {
      closeModal('modal-anular');
      if (res.exito) {
        showToast('Evento anulado.', 'success');
        setTimeout(function () { window.location.reload(); }, 1000);
      } else {
        showToast(res.mensaje || 'No se pudo anular el evento.', 'error');
      }
    })
    .catch(function () { showToast('Error de conexión. Intenta nuevamente.', 'error'); });
  });

  /* ── Gestión de solicitudes (aprobar / rechazar / reversar) ─ */
  var gestionEventoId = null;
  var gestionRequiereObs = false;

  function getOpcionesTransicion(estado) {
    if (estado === 'Pendiente')
      return [{ value: 'Aprobado',  label: 'Aprobar' },
              { value: 'Rechazado', label: 'Rechazar' }];
    if (estado === 'Aprobado')
      return [{ value: 'Pendiente', label: 'Devolver a Pendiente' },
              { value: 'Rechazado', label: 'Rechazar' }];
    if (estado === 'Rechazado')
      return [{ value: 'Aprobado',  label: 'Aprobar' },
              { value: 'Pendiente', label: 'Devolver a Pendiente' }];
    return [];
  }

  function esObligatoriaObservacion(estadoActual, nuevoEstado) {
    return nuevoEstado === 'Rechazado' ||
           estadoActual === 'Aprobado' ||
           estadoActual === 'Rechazado';
  }

  function actualizarGrupObservacion(estadoActual, nuevoEstado) {
    var obligatoria = esObligatoriaObservacion(estadoActual, nuevoEstado);
    gestionRequiereObs = obligatoria;
    document.getElementById('gest-obs-required').hidden = !obligatoria;
    document.getElementById('gest-obs-hint').textContent = obligatoria
      ? 'Obligatoria al rechazar o reversar una decisión.'
      : 'Opcional.';
  }

  window.iniciarGestion = function (id, estadoActual) {
    gestionEventoId = id;
    var sel = document.getElementById('gest-nuevo-estado');
    sel.innerHTML = '';
    getOpcionesTransicion(estadoActual).forEach(function (op) {
      var opt = document.createElement('option');
      opt.value = op.value;
      opt.textContent = op.label;
      sel.appendChild(opt);
    });
    document.getElementById('gest-observacion').value = '';
    actualizarGrupObservacion(estadoActual, sel.value);
    sel.addEventListener('change', function () {
      actualizarGrupObservacion(estadoActual, this.value);
    });
    openModal('modal-gestion');
  };

  var btnConfGest = document.getElementById('btn-confirmar-gestion');
  if (btnConfGest) {
    btnConfGest.addEventListener('click', function () {
      var nuevoEstado = document.getElementById('gest-nuevo-estado').value;
      var observacion = document.getElementById('gest-observacion').value.trim();

      if (gestionRequiereObs && !observacion) {
        showToast('La observación es obligatoria para esta acción.', 'error'); return;
      }

      var data = new FormData();
      data.append('id', gestionEventoId);
      data.append('nuevoEstado', nuevoEstado);
      if (observacion) data.append('observacion', observacion);

      fetch('@Url.Action("CambiarEstadoAjax", "EventoLaboral")', {
        method: 'POST',
        headers: { 'RequestVerificationToken': getToken() },
        body: data
      })
      .then(function (r) { return r.json(); })
      .then(function (res) {
        closeModal('modal-gestion');
        if (res.exito) {
          showToast(res.mensaje || 'Solicitud actualizada.', 'success');
          setTimeout(function () { window.location.reload(); }, 1000);
        } else {
          showToast(res.mensaje || 'No se pudo actualizar la solicitud.', 'error');
        }
      })
      .catch(function () { showToast('Error de conexión. Intenta nuevamente.', 'error'); });
    });
  }

  /* ── Close modal resets form ─────────────────────────────── */
  document.querySelectorAll('[data-modal-close]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var overlay = btn.closest('.modal-overlay');
      if (overlay && overlay.id === 'modal-nuevo-evento') resetModal();
    });
  });

}());
</script>
}

@functions {
    string BadgeEstado(string estado) => estado.ToLower() switch
    {
        "pendiente"  => "<span class=\"badge badge--pendiente\"><span class=\"badge-dot\"></span>Pendiente</span>",
        "aprobado"   => "<span class=\"badge badge--aprobado\"><span class=\"badge-dot\"></span>Aprobado</span>",
        "rechazado"  => "<span class=\"badge badge--rechazado\"><span class=\"badge-dot\"></span>Rechazado</span>",
        "enrevision" => "<span class=\"badge badge--en-revision\"><span class=\"badge-dot\"></span>En revisión</span>",
        "activo"     => "<span class=\"badge badge--activo\"><span class=\"badge-dot\"></span>Activo</span>",
        "finalizado" => "<span class=\"badge badge--finalizado\"><span class=\"badge-dot\"></span>Finalizado</span>",
        "anulado"    => "<span class=\"badge badge--anulado\"><span class=\"badge-dot\"></span>Anulado</span>",
        _            => $"<span class=\"badge\">{System.Net.WebUtility.HtmlEncode(estado)}</span>",
    };
    string BadgeTipo(string tipo) => tipo.ToLower() switch
    {
        "vacaciones"  => "<span class=\"badge badge--vacaciones\">Vacaciones</span>",
        "incapacidad" => "<span class=\"badge badge--incapacidad\">Incapacidad</span>",
        "permiso"     => "<span class=\"badge badge--permiso\">Permiso</span>",
        _             => $"<span class=\"badge\">{System.Net.WebUtility.HtmlEncode(tipo)}</span>",
    };
}
